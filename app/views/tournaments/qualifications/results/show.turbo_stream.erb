<% editable = policy(@tournament).update? %>

<% header_actions = capture do %>
  <% if @result.track.present? %>
    <%= link_to track_path(@result.track), class: 'button button--ghost button--sm', target: '_blank' do %>
      <%= icon_tag 'up-right-from-square' %>
      <%= t('general.open_track') %>
    <% end %>
  <% end %>
<% end %>

<%= turbo_stream.update 'modal-root' do %>
  <%= render partial: 'tournaments/qualifications/results/result',
             layout: 'components/dialog',
             locals: {
               title: qualification_jump_presentation(@result),
               dialog_size: 'lg',
               header_actions:,
               result: @result,
               modal: true,
               editable:
             } %>
<% end %>
