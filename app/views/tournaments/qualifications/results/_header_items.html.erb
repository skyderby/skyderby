<% local ||= false %>
<% current_controller = controller.controller_path.split('/').last %>
<% link_data = local ? {} : { turbo_stream: true } %>

<%= link_to t('general.charts'),
            tournament_qualification_result_path(@tournament, @result),
            data: link_data,
            class: class_names('tab-bar-item', current_controller == 'results' && 'active') %>

<%= link_to t('general.jump_range'),
            tournament_qualification_result_jump_range_path(@tournament, @result),
            data: link_data,
            class: class_names('tab-bar-item', current_controller == 'jump_ranges' && 'active') %>
