<% provide :title, @tournament.name %>

<div class="display-wrap"
     data-controller="slideshow refresh"
     data-refresh-interval-seconds-value="300">
  <div class="display-stage">
    <div class="display-backdrop"></div>

    <% leader = @competitors.first %>
    <% groups = @competitors.each_slice(8).to_a %>
    <% groups = [[]] if groups.empty? %>
    <% groups.each_with_index do |group, group_index| %>
      <%= render 'leaderboard', tournament: @tournament, competitors: @competitors, active: group_index.zero? %>

      <% group.each do |competitor| %>
        <%= render 'participant',
                   tournament: @tournament,
                   competitor: competitor,
                   leader: leader,
                   field_size: @competitors.size %>
      <% end %>
    <% end %>

    <% @scoreboard.head_to_head_replays.each do |replay| %>
      <%= render 'replay', tournament: @tournament, replay: replay %>
    <% end %>
  </div>
</div>
