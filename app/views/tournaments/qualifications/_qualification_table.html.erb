<%# locals: (tournament:, scoreboard:, editable:) %>
<% show_best = scoreboard.show_best_result? %>
<% podium = scoreboard.podium? %>

<table class="scoreboard-table scoreboard-table--compact scoreboard-table--pinned-competitor qualification-scoreboard-table" data-events--sticky-header-target="table">
  <thead>
    <tr>
      <%= render 'scoreboards/pinned_competitor_header', label: t('tournaments.qualifications.scoreboard.competitor'), rowspan: 2 %>
      <td class="text-center" rowspan="2"><%= t('tournaments.qualifications.scoreboard.rank') %></td>
      <td class="<%= class_names 'text-center', (!show_best && 'scoreboard-table-separate-border') %>" colspan="2" rowspan="2"><%= t('tournaments.qualifications.scoreboard.competitor') %></td>
      <% if show_best %>
        <td class="text-center scoreboard-table-separate-border" rowspan="2"><%= t('tournaments.qualifications.scoreboard.best_result') %></td>
      <% end %>
      <% scoreboard.rounds.each do |round| %>
        <th class="round" colspan="2">
          <% unless show_best %>
            <div class="round-status" data-controller="tooltip">
              <% if round.completed? %>
                <%= icon_tag 'circle-check-regular', class: 'round-completed' %>
                <span class="for-screen-reader"><%= t('events.rounds.completed_tooltip') %></span>
              <% elsif editable %>
                <%= icon_tag 'circle-regular', class: 'round-not-completed-icon' %>
                <span class="for-screen-reader"><%= t('events.rounds.mark_completed_tooltip') %></span>
              <% end %>
            </div>
          <% end %>

          <%= t('tournaments.qualifications.scoreboard.round', number: round.order) %>

          <% if editable %>
            <div class="cell-actions" data-controller="dropdown">
              <button class="dropdown-toggle button button--ghost button--sm" popovertarget="qual-round-menu-<%= round.id %>">
                <%= icon_tag 'ellipsis-vertical-solid' %>
              </button>

              <div id="qual-round-menu-<%= round.id %>" popover class="sd-dropdown-menu" data-dropdown-target="menu">
                <% unless show_best %>
                  <% if round.completed? %>
                    <%= button_to t('events.rounds.mark_not_completed'),
                                  tournament_qualification_round_path(tournament, round),
                                  method: :patch, params: { qualification_round: { completed: false } },
                                  form: { data: { turbo_stream: true } }, class: 'dropdown-item' %>
                  <% else %>
                    <%= button_to t('events.rounds.mark_completed'),
                                  tournament_qualification_round_path(tournament, round),
                                  method: :patch, params: { qualification_round: { completed: true } },
                                  form: { data: { turbo_stream: true } }, class: 'dropdown-item' %>
                  <% end %>

                  <div class="dropdown-divider"></div>
                <% end %>

                <%= button_to tournament_qualification_round_path(tournament, round), method: :delete, data: { turbo_stream: true }, class: 'dropdown-item' do %>
                  <%= icon_tag 'xmark', class: 'text-muted' %>
                  <%= t('general.delete') %>
                <% end %>
              </div>
            </div>
          <% end %>
        </th>
      <% end %>
    </tr>
    <tr>
      <% scoreboard.rounds.each do |round| %>
        <td class="text-center round-result"><%= t('tournaments.qualifications.scoreboard.result') %></td>
        <td class="text-center round-canopy"><%= t('tournaments.qualifications.scoreboard.canopy') %></td>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% scoreboard.competitors.each do |competitor| %>
      <% on_podium = podium && competitor.ranked? && competitor.rank <= 3 %>
      <tr class="<%= class_names('scoreboard-competitor', ("podium-row--#{competitor.rank}" if on_podium)) %>">
        <%= render 'scoreboards/pinned_competitor_cell', name: competitor.name %>
        <td class="text-center rank-cell">
          <% if !competitor.ranked? %>
            –
          <% elsif on_podium %>
            <span class="rank-badge rank-badge--<%= competitor.rank %>"><%= competitor.rank %></span>
          <% else %>
            <%= competitor.rank %>
          <% end %>
        </td>
        <td class="competitor">
          <%= link_to competitor.name, profile_path(competitor.profile_id), class: 'competitor-profile' %>
          <% if competitor.is_disqualified %>
            <span class="text-danger" data-controller="tooltip">(DQ)<span class="for-screen-reader"><%= competitor.disqualification_reason %></span></span>
          <% end %>
          <div class="competitor-suit text-gray">
            <%= competitor.suit.manufacturer_code %>
            <%= competitor.suit_name %>
          </div>

          <% if editable %>
            <div class="cell-actions" data-controller="dropdown">
              <button class="dropdown-toggle button button--ghost button--sm" popovertarget="qual-competitor-menu-<%= competitor.id %>">
                <%= icon_tag 'ellipsis-vertical-solid' %>
              </button>

              <div id="qual-competitor-menu-<%= competitor.id %>" popover class="sd-dropdown-menu" data-dropdown-target="menu">
                <%= button_to edit_tournament_competitor_path(tournament, competitor), method: :get, form: { data: { turbo_stream: true } }, class: 'dropdown-item' do %>
                  <%= icon_tag 'pencil-solid', class: 'text-muted' %>
                  <%= t('general.edit') %>
                <% end %>

                <%= button_to tournament_competitor_path(tournament, competitor), method: :delete, form: { data: { turbo_stream: true, confirm: t('general.confirm_delete') } }, class: 'dropdown-item' do %>
                  <%= icon_tag 'xmark', class: 'text-muted' %>
                  <%= t('general.delete') %>
                <% end %>
              </div>
            </div>
          <% end %>
        </td>
        <td class="<%= class_names 'text-center', 'competitor-country', (!show_best && 'scoreboard-table-separate-border') %>">
          <span data-controller="tooltip"><%= competitor.country_code %><span class="for-screen-reader"><%= competitor.country_name %></span></span>
        </td>
        <% if show_best %>
          <td class="scoreboard-table-separate-border text-center result-value best-result-value">
            <%= number_with_precision(competitor.best_result, precision: 3) %>
            <% if competitor.best_result.present? %>
              <%= render 'tournaments/qualifications/result_gap', gap: competitor.best_result.to_f - scoreboard.best_result_leader.to_f %>
            <% end %>
          </td>
        <% end %>
        <% scoreboard.rounds.each do |round| %>
          <% result = competitor.result_in_round(round) %>
          <% if result&.result.present? %>
            <td class="<%= class_names 'result-cell', 'round-result', ('text-green' if competitor.best_result_in?(result)) %>">
              <%= link_to tournament_qualification_result_path(tournament, result),
                          **(mobile? ? { target: '_blank' } : { data: { turbo_stream: true } }),
                          class: 'result-show-cell', rel: 'nofollow' do %>
                <%= number_with_precision(result.result, precision: 3) %>
              <% end %>
              <% if !show_best && result.result.positive? && (leader = scoreboard.round_leader_result(round)) %>
                <%= render 'tournaments/qualifications/result_gap', gap: result.result.to_f - leader.to_f %>
              <% end %>
            </td>
            <td class="<%= class_names('text-left result-value round-canopy', 'canopy-low' => result.canopy_time.present? && result.canopy_time < 40) %>">
              <span data-controller="tooltip"><%= number_with_precision(result.canopy_time, precision: 1) %><span class="for-screen-reader"><%= t('tournaments.qualifications.scoreboard.canopy_time') %></span></span>
            </td>
          <% elsif result.present? && editable %>
            <td class="result-cell round-result">
              <%= link_to icon_tag('circle-question', class: 'text-danger'),
                          tournament_qualification_result_path(tournament, result),
                          **(mobile? ? { target: '_blank' } : { data: { turbo_stream: true } }),
                          class: 'result-show-cell', rel: 'nofollow' %>
            </td>
            <td class="round-canopy"></td>
          <% elsif editable %>
            <td class="result-cell round-result">
              <%= button_to icon_tag('upload-solid'),
                            new_tournament_qualification_result_path(tournament),
                            params: {
                              'result[competitor_id]' => competitor.id,
                              'result[qualification_round_id]' => round.id
                            },
                            method: :get, form: { data: { turbo_stream: true }, class: 'result-upload-cell' } %>
            </td>
            <td class="round-canopy"></td>
          <% else %>
            <td class="round-result"></td>
            <td class="round-canopy"></td>
          <% end %>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
