<div id="tournament-form" data-controller="tournaments--form">
  <div class="col-sm-6">
    <%= form_for @tournament do |f| %>

      <div class="form-row">
        <%= f.label :name, class: 'form-label col-sm-2' %>
        <div class="col-sm-10">
          <%= f.text_field :name, class: 'form-input' %>
        </div>
      </div>

      <div class="form-row">
        <%= f.label :place, class: 'form-label col-sm-2' %>
        <div class="col-sm-10">
          <%= render 'hot_select/select',
                     form: f,
                     name: :place_id,
                     src: places_select_options_path,
                     placeholder: t('events.show.place_placeholder'),
                     options: options_for_select([[@tournament.place_name, @tournament.place_id]], @tournament.place_id),
                     select: { data: { action: 'change->tournaments--form#on_change_place' } } %>
        </div>
      </div>

      <div class="form-row">
        <%= f.label :finish_line, class: 'col-sm-2 form-label' %>
        <div class="col-sm-5">
          <% finish_line_options = @tournament.finish_line ? options_for_select([[@tournament.finish_line.name, @tournament.finish_line_id]], @tournament.finish_line_id) : [] %>
          <%= render 'hot_select/select',
                     form: f,
                     name: :finish_line_id,
                     src: places_finish_lines_select_options_path(place_id: @tournament.place_id),
                     options: finish_line_options,
                     placeholder: t('tournaments.form.finish_line_placeholder'),
                     select: { data: { 'tournaments--form-target': 'finishLineSelect' } } %>
        </div>
      </div>

      <div class="form-row">
        <%= f.label :starts_at, class: 'form-label col-sm-2' %>
        <div class="col-sm-10">
          <%= f.date_field :starts_at, class: 'form-input' %>
        </div>
      </div>

      <div class="form-row">
        <%= f.label :bracket_size, class: 'form-label col-sm-2' %>
        <div class="col-sm-10">
          <%= f.text_field :bracket_size, class: 'form-input' %>
        </div>
      </div>

      <div class="form-row">
        <div class="col-sm-4 col-sm-offset-2">
          <label class="form-checkbox">
            <%= f.check_box :has_qualification %>
            Has qualification
          </label>
        </div>
      </div>

      <div class="form-row">
        <%= f.label :qualification_scoring, t('tournaments.qualification_scoring.label'), class: 'form-label col-sm-2' %>
        <div class="col-sm-10 form-radio-group">
          <% Tournament.qualification_scorings.each_key do |scoring| %>
            <label class="form-radio">
              <%= f.radio_button :qualification_scoring, scoring %>
              <%= t("tournaments.qualification_scoring.#{scoring}") %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="col-sm-offset-2 col-sm-8">
        <%= f.submit nil, class: 'button button--primary' %>
        <% path = @tournament.persisted? ? tournament_path(@tournament) : events_path %>
        <%= link_to t('general.cancel'), path, class: 'button' %>
      </div>

    <% end %>
  </div>
</div>
