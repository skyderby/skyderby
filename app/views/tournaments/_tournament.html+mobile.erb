<% cache ['mobile', I18n.locale, tournament] do %>
  <%= link_to tournament_path(tournament), class: ['events-list__item', ('active' if tournament.active?)] do %>
    <div class="events-list__item-sidebar">
      <div class="events-list__item-date">
        <%= tournament.starts_at.strftime '%d' %>
        <span><%= tournament.starts_at.strftime '%b\'%y' %></span>
      </div>
      <div class="events-list__item-official"><%= official %></div>
    </div>
    <div class="events-list__item-content">
      <div class="events-list__item-title"><%= tournament.name %></div>
      <% if tournament.place.present? %>
        <div class="event__place">
          <i class="fa fa-map-marker-alt"></i>
          <%= tournament.place.name %>
          <span><%= tournament.place.country_code %></span>
        </div>
      <% end %>
      <div class="events-list__item-participants">
        <p>
          Open –
          <span><%= tournament.competitors.count %></span>
        </p>
      </div>
      <hr>
      <div class="events-list__item-info">
        Rules:
        <span>Single elimination</span>
      </div>
    </div>
  <% end %>
<% end %>
