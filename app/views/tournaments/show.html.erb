<% provide :title, @tournament.name %>
<% editable = policy(@tournament).update? %>

<div class="show-page">
  <%= render 'tournaments/header', editable: %>

  <div class="container">
    <% if editable %>
      <%= render 'actions_bar', tournament: @tournament, editable: %>
    <% end %>

    <div class="content-block">
      <% if @tournament.surprise? && !editable %>
        <h1 class="text-muted text-center">
          🙅 Let it be a Surprise
        </h1>
      <% else %>
        <%= render 'scoreboard' %>
      <% end %>
    </div>
  </div>

  <div class="container">
    <%= render 'footer', editable: editable %>
  </div>
</div>
