<% type_modifier = match.gold_finals? ? 'gold' : (match.bronze_finals? ? 'bronze' : nil) %>

<div class="bracket-cell <%= "bracket-cell--#{type_modifier}" if type_modifier %>">
  <div class="bracket-match <%= "bracket-match--#{type_modifier}" if type_modifier %>">
    <header class="bracket-match__head">
      <span class="bracket-match__title">
        <%= tournament_match_label(match, index, order, rounds_count) %>
      </span>

      <div class="bracket-match__links">
        <% if editable %>
          <div class="cell-actions" data-controller="dropdown">
            <button class="dropdown-toggle button button--ghost button--sm" popovertarget="match-menu-<%= match.id %>">
              <%= icon_tag 'ellipsis-vertical-solid' %>
            </button>

            <div id="match-menu-<%= match.id %>" popover class="sd-dropdown-menu" data-dropdown-target="menu">
              <%= button_to edit_tournament_match_path(@tournament, match), method: :get, form: { data: { turbo_stream: true } }, class: 'dropdown-item' do %>
                <%= icon_tag 'pencil-solid', class: 'text-muted' %>
                <%= t('general.edit') %>
              <% end %>

              <% unless round_final %>
                <% if index > 1 %>
                  <%= button_to tournament_match_position_path(@tournament, match), method: :patch, params: { direction: 'up' }, form: { data: { turbo_stream: true } }, class: 'dropdown-item' do %>
                    <%= icon_tag 'angle-up-solid', class: 'text-muted' %>
                    <%= t('tournaments.bracket.move_up') %>
                  <% end %>
                <% end %>

                <% if index < total %>
                  <%= button_to tournament_match_position_path(@tournament, match), method: :patch, params: { direction: 'down' }, form: { data: { turbo_stream: true } }, class: 'dropdown-item' do %>
                    <%= icon_tag 'angle-down-solid', class: 'text-muted' %>
                    <%= t('tournaments.bracket.move_down') %>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </header>

    <ul class="bracket-match__slots">
      <% match.slots.each do |slot| %>
        <li class="bracket-slot <%= "bracket-slot--#{slot.earn_medal}" if slot.earn_medal %> <%= 'bracket-slot--winner' if slot.is_winner %>"
            <% if slot.competitor.present? %>data-competitor-id="<%= slot.competitor_id %>" data-action="mouseenter->tournaments--bracket#highlight mouseleave->tournaments--bracket#reset"<% end %>>
          <% if slot.competitor.present? %>
            <a class="bracket-slot__profile" href="<%= profile_path(slot.competitor.profile_id) %>">
              <%= tournament_competitor_avatar(slot.competitor) %>
              <span class="bracket-slot__name"><%= slot.competitor.name %></span>
            </a>
          <% else %>
            <span class="bracket-slot__profile bracket-slot__profile--empty">
              <span class="bracket-avatar bracket-avatar--empty">?</span>
            </span>
          <% end %>

          <span class="bracket-slot__result">
            <% has_result = slot.result.present? || slot.track.present? %>

            <% result_html = capture do %>
              <% if slot.is_winner %>
                <%= icon_tag 'check-solid', class: 'bracket-slot__check' %>
              <% end %>
              <% if slot.result.present? %>
                <% formatted = number_with_precision(slot.result, precision: 3) %>
                <%= slot.is_disqualified ? content_tag(:s, formatted) : formatted %>
              <% end %>
            <% end %>

            <% if editable && !has_result %>
              <%= link_to new_tournament_match_slot_result_path(@tournament, match, slot), data: { turbo_stream: true }, class: 'button button--ghost button--sm' do %>
                <%= icon_tag 'upload-solid', class: 'icon--fw text-muted' %>
              <% end %>
            <% elsif editable || slot.track_id %>
              <%= link_to tournament_match_slot_result_path(@tournament, match, slot), data: { turbo_stream: true, toggle: 'tooltip' }, title: slot.notes do %>
                <%= result_html %>
              <% end %>
            <% else %>
              <%= result_html %>
            <% end %>
          </span>
        </li>
      <% end %>

      <% match.free_slots.times do %>
        <li class="bracket-slot">
          <span class="bracket-slot__profile bracket-slot__profile--empty">
            <span class="bracket-avatar bracket-avatar--empty">?</span>
          </span>
        </li>
      <% end %>
    </ul>
  </div>
</div>
