<div class="modal-dialog modal-lg">
  <div class="modal-content">
    <div class="modal-header">
      <div class="pull-right">
        <%= link_to @slot.track, class: 'modal-header-link', target: '_blank' do %>
          <%= icon_tag 'up-right-from-square' %>
        <% end %>
        <button type="button" class="close" data-dismiss="modal">
          <span aria-hidden="true">&times;</span>
          <span class="sr-only">Close</span>
        </button>
      </div>
      <h4 class="modal-title">
        <%= match_slot_presentation(@slot) %>
      </h4>
    </div>

    <div class="modal-body">
      <div class="container-fluid">
        <%= render 'tournaments/matches/slots/header' %>
        <div class="row">
          <div class="col-sm-12">
            <div class="pull-right">
              <%= render 'tracks/view_settings_menu', presenter: @track_presenter %>
            </div>
          </div>
        </div>

        <%= render partial: 'tracks/indicators', locals: { presenter: @track_presenter } %>

        <hr>
        <div class="row">
          <div class="col-sm-12">
            <%= render 'tracks/charts', presenter: @track_presenter %>
          </div>
        </div>
      </div>
    </div>

    <div class="modal-footer">
      <div class="modal-actions">
        <div class="modal-actions__left">
          <%= link_to t('general.delete'), tournament_match_slot_result_path(@tournament, @match, @slot), remote: true, method: :delete, class: 'btn-flat btn-flat--danger' %>
        </div>
        <div class="modal-actions__right">
          <button type="button" class="btn btn-default" data-dismiss="modal">OK</button>
        </div>
      </div>
    </div>
  </div>
</div>
