<div class="container-fluid">
  <div class="tournaments-match-map" data-controller="tournaments--match-map"
       data-url="<%= url_for %>"
       data-action="maps_api:ready@window->tournaments--match-map#on_maps_api_ready maps_api:failed@window->tournaments--match-map#on_maps_load_failed">
    <div id="track-map-loading" class="text-muted" data-tournaments--match-map-target="placeholder">
      <div class="fa-2x">
        <i class="fa fa-fw fa-spin fa-circle-notch" data-tournaments--match-map-target="maps_loading_status"></i>
        Loading Google Maps API
      </div>
      <div class="fa-2x">
        <i class="fa fa-fw fa-spin fa-circle-notch" data-tournaments--match-map-target="data_loading_status"></i>
        Loading track data
      </div>
    </div>
    <div id="match-map" data-tournaments--match-map-target="map"></div>
  </div>

  <div class="center-block text-center top-buffer">
    <% @match_map.competitors.each do |competitor| %>
      <span>
        <i class="fa fa-fw fa-circle" style="color: <%= competitor.color %>"></i>
        <span><%= competitor.name %></span>
      </span>
    <% end %>
  </div>
</div>
