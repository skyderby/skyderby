<% form_path = @competitor.new_record? ? tournament_competitors_path(@tournament) : tournament_competitor_path(@tournament, @competitor) %>

<%= form_with model: @competitor, url: form_path, multipart: true, data: { controller: 'modal-form', action: 'form:submit-success->dialog#close' } do |f| %>
  <div class="sd-form">
    <h3 class="form-section-title">
      <%= t('competitors.form.profile') %>
    </h3>

    <%= render 'competitors/profile_fields', f:, competitor: @competitor, event: @tournament %>

    <div class="form-divider"></div>

    <h3 class="form-section-title">
      <%= Tournament::Competitor.human_attribute_name(:suit) %>
    </h3>

    <div class="grid">
      <%= f.label :suit, class: 'form-label col-4' %>
      <%= render 'hot_select/select',
                 form: f,
                 name: :suit_id,
                 src: suits_select_options_path,
                 placeholder: 'Choose suit',
                 options: options_for_select([[@competitor.suit_name, @competitor.suit_id]], @competitor.suit_id),
                 class: 'col-8' %>
    </div>

    <div class="form-divider"></div>

    <h3 class="form-section-title">
      <%= t('competitors.form.show_images') %>
    </h3>

    <div class="grid">
      <%= f.label :photo, Tournament::Competitor.human_attribute_name(:photo), class: 'form-label col-4' %>
      <div class="col-8">
        <% if @competitor.photo %>
          <div class="form-static"><%= image_tag @competitor.photo_url(:medium), class: 'competitor-image-preview' %></div>
        <% end %>
        <div data-controller="filefield">
          <%= f.hidden_field :photo, value: @competitor.cached_photo_data %>
          <%= f.file_field :photo, class: 'form-input',
                           data: { filefield_target: 'file_field', action: 'change->filefield#change' } %>
          <div class="file-name" data-filefield-target="text_field"></div>
        </div>
      </div>
    </div>

    <div class="grid">
      <%= f.label :sponsor_logo, Tournament::Competitor.human_attribute_name(:sponsor_logo), class: 'form-label col-4' %>
      <div class="col-8">
        <% if @competitor.sponsor_logo %>
          <div class="form-static"><%= image_tag @competitor.sponsor_logo_url(:medium), class: 'competitor-image-preview' %></div>
        <% end %>
        <div data-controller="filefield">
          <%= f.hidden_field :sponsor_logo, value: @competitor.cached_sponsor_logo_data %>
          <%= f.file_field :sponsor_logo, class: 'form-input',
                           data: { filefield_target: 'file_field', action: 'change->filefield#change' } %>
          <div class="file-name" data-filefield-target="text_field"></div>
        </div>
      </div>
    </div>

    <% unless @competitor.new_record? %>
      <div class="form-divider"></div>

      <div class="grid">
        <%= f.label :is_disqualified, class: 'form-label col-4' %>
        <div class="col-8">
          <label class="form-checkbox">
            <%= f.check_box :is_disqualified %>
          </label>
        </div>
      </div>

      <div class="grid">
        <%= f.label :disqualification_reason, class: 'form-label col-4' %>
        <%= f.text_field :disqualification_reason, class: 'form-input col-8' %>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
      <button type="button" class="button" data-action="dialog#close"><%= t 'general.cancel' %></button>
    </div>
  </div>
<% end %>
