<% editable ||= false %>

<div class="show-page-header">
  <h1 class="show-page-title">
    <%= @tournament.name %>
  </h1>

  <div class="show-page-info">
    <%= icon_tag 'location-dot-solid' %>
    <%= place_presentation(@tournament.place) %>
  </div>

  <div class="page-nav">
    <% controller_path = controller.controller_path %>
    <% if @tournament.rounds.any? || editable %>
      <%= link_to tournament_path(@tournament), class: ['page-tab', ('page-tab-active' if controller_path == 'tournaments' && action_name == 'show')] do %>
        Scoreboard
      <% end %>
    <% end %>
    <% if @tournament.has_qualification %>
      <%= link_to tournament_qualification_path(@tournament), class: ['page-tab', ('page-tab-active' if controller_path == 'tournaments/qualifications')] do %>
        Qualification
      <% end %>
    <% end %>
    <% if editable %>
      <%= link_to tournament_competitors_path(@tournament.id),  class: ['page-tab', ('page-tab-active' if controller_path == 'tournaments/competitors')] do %>
        Competitors
      <% end %>

      <%= link_to edit_tournament_path(@tournament), class: ['page-tab page-tab-right', ('page-tab-active' if controller_path == 'tournaments' && action_name == 'edit')] do %>
        <%= icon_tag 'gear-solid' %>
        <%= t('general.edit') %>
      <% end %>
    <% end %>
  </div>
</div>
