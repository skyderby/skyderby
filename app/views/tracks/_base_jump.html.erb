<% content_for :head do %>
  <meta name="track-kind" content="<%= @track.kind %>">
  <meta name="track-pro-view" content="true">
<% end %>

<div class="show-page">
  <%= render partial: 'header', locals: { track: @track } %>

  <% default_jump_line = @track.place&.jump_lines&.first %>
  <% compare_same_place = @compare_track && @track.place_id.present? && @track.place_id == @compare_track.place_id %>
  <% race = @track.race_finish_line %>
  <% finish_line_coords = race && race[:finish_line]&.to_coordinates %>
  <div class="track-show-content"
       data-controller="tracks--base-jump-track"
       data-tracks--base-jump-track-points-url-value="<%= track_points_path(@track, original_frequency: true, trimmed: { seconds_before_start: 2, seconds_after_end: 10 }) %>"
       data-tracks--base-jump-track-location-arrow-url-value="<%= asset_path('icons/location-arrow.svg') %>"
       data-tracks--base-jump-track-track-id-value="<%= @track.id %>"
       <% if @compare_track %>
       data-tracks--base-jump-track-compare-points-url-value="<%= track_points_path(@compare_track, original_frequency: true, trimmed: { seconds_before_start: 2, seconds_after_end: 10 }) %>"
       data-tracks--base-jump-track-compare-track-name-value="<%= @compare_track.pilot&.name || @compare_track.name %>"
       data-tracks--base-jump-track-compare-same-place-value="<%= compare_same_place %>"
       <% end %>
       <% if finish_line_coords.present? %>
       data-tracks--base-jump-track-finish-line-start-lat-value="<%= finish_line_coords.first[:latitude] %>"
       data-tracks--base-jump-track-finish-line-start-lon-value="<%= finish_line_coords.first[:longitude] %>"
       data-tracks--base-jump-track-finish-line-end-lat-value="<%= finish_line_coords.last[:latitude] %>"
       data-tracks--base-jump-track-finish-line-end-lon-value="<%= finish_line_coords.last[:longitude] %>"
       data-tracks--base-jump-track-race-result-time-value="<%= race[:result] %>"
       <% end %>
       data-tracks--base-jump-track-default-terrain-profile-id-value="<%= default_jump_line&.id %>">

    <div class="base-jump-toolbar">
      <% if finish_line_coords.present? %>
        <div class="switch-container">
          <input type="checkbox"
                 id="finish-line-toggle"
                 class="switch-input"
                 data-tracks--base-jump-track-target="finishLineToggle"
                 data-action="tracks--base-jump-track#toggleFinishLine">
          <label for="finish-line-toggle" class="switch-label">
            <span class="switch-slider"></span>
            <span class="switch-text"><%= t('tracks.base_jump.finish_line') %></span>
          </label>
        </div>
      <% end %>

      <div class="switch-container">
        <input type="checkbox"
               id="expand-map-toggle"
               class="switch-input"
               data-tracks--base-jump-track-target="expandMapToggle"
               data-action="tracks--base-jump-track#toggleExpandMap">
        <label for="expand-map-toggle" class="switch-label">
          <span class="switch-slider"></span>
          <span class="switch-text"><%= t('tracks.base_jump.expand_map') %></span>
        </label>
      </div>

      <div class="comparison-actions">
        <% if @compare_track %>
          <a href="<%= track_path(@track) %>" class="button button--sm button--outline button--danger">
            <%= t('tracks.comparison.remove') %>
          </a>
        <% else %>
          <button type="button"
                  class="button button--sm button--outline button--primary"
                  data-action="tracks--base-jump-track#openCompareModal">
            <%= t('tracks.comparison.compare_button') %>
          </button>
        <% end %>
      </div>
    </div>

    <%= render 'tracks/comparison_modal', controller: 'tracks--base-jump-track', kind: :base %>

    <div class="base-jump-layout">
      <div class="base-jump-left">
        <div class="base-jump-chart-square"
             data-tracks--base-jump-track-target="sideProjection">
        </div>

        <div class="base-jump-terrain-select">
          <label><%= t('tracks.base_jump.terrain_profile') %></label>
          <%= render 'hot_select/select',
                     name: :terrain_profile_id,
                     src: places_jump_profiles_select_options_path,
                     placeholder: t('tracks.base_jump.select_terrain_profile'),
                     options: default_jump_line.present? ? options_for_select([["#{default_jump_line.place.name} - #{default_jump_line.name}", default_jump_line.id]], default_jump_line.id) : [],
                     select: { data: { action: 'tracks--base-jump-track#handleTerrainProfileSelection', 'tracks--base-jump-track-target': 'terrainProfileSelect' } } %>
        </div>
      </div>

      <div class="base-jump-controls">
        <div class="base-jump-indicators-row">
          <%= render 'tracks/playback_indicators', data: { 'tracks--base-jump-track-target': 'playbackIndicators' } %>
          <% if @compare_track %>
            <%= render 'tracks/playback_indicators', compare: true, data: { 'tracks--base-jump-track-target': 'comparePlaybackIndicators' } %>
          <% end %>
        </div>

        <div class="base-jump-playback">
          <button class="base-jump-playback-button"
                  data-tracks--base-jump-track-target="playButton"
                  data-action="tracks--base-jump-track#togglePlay">
            <span class="icon-play"><%= icon_tag 'play-solid' %></span>
            <span class="icon-pause"><%= icon_tag 'pause-solid' %></span>
          </button>
          <input type="range"
                 class="base-jump-playback-slider"
                 min="0"
                 max="100"
                 value="0"
                 data-tracks--base-jump-track-target="playbackSlider"
                 data-action="input->tracks--base-jump-track#onSliderInput">
        </div>
      </div>

      <div class="base-jump-right">
        <div class="base-jump-map-container">
          <div class="base-jump-map"
               data-tracks--base-jump-track-target="map">
          </div>
        </div>

        <div class="base-jump-charts"
             data-controller="synchronized-charts"
             data-action="mousemove->synchronized-charts#refreshTooltip touchmove->synchronized-charts#refreshTooltip touchstart->synchronized-charts#refreshTooltip">
          <div class="base-jump-glide-chart"
               data-tracks--base-jump-track-target="glideChart"
               data-synchronized-charts-target="chart"></div>
          <div class="base-jump-speed-chart"
               data-tracks--base-jump-track-target="speedChart"
               data-synchronized-charts-target="chart"></div>
          <div class="base-jump-sep-chart"
               data-tracks--base-jump-track-target="sepChart"
               data-synchronized-charts-target="chart"></div>
        </div>
      </div>
    </div>

    <blockquote class="flex flex-column">
      <%= render 'track_metadata' %>
    </blockquote>
  </div>
</div>
