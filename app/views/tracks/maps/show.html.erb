<% provide :title, title(@track) %>

<div class="show-page">
  <%= render partial: 'tracks/header', locals: { track: @track } %>

  <div class="track-show-content">
    <div class="row" data-controller="tracks--map" data-url="<%= url_for %>" data-action="maps_api:ready@window->tracks--map#on_maps_ready maps_api:failed@window->tracks--map#on_maps_load_failed">
      <div class="track-map-wrapper col-sm-12">
        <div id="track-map-loading" class="text-muted" data-target="tracks--map.placeholder">
          <div class="fa-2x">
            <i class="fa fa-fw fa-spin fa-circle-notch" data-target="tracks--map.maps_loading_status"></i>
            Loading Google Maps API
          </div>
          <div class="fa-2x">
            <i class="fa fa-fw fa-spin fa-circle-notch" data-target="tracks--map.data_loading_status"></i>
            Loading track data
          </div>
        </div>
        <div id="track-map" data-target="tracks--map.map"></div>
        <% if @track.weather_data.exists? %>
          <div id="track-map-polar-chart" data-controller="tracks--wind-chart" data-url="<%= track_weather_data_path(@track) %>"></div>
        <% end %>
        <%= render 'tracks/speed_grades' %>
      </div>
    </div>
  </div>
</div>
