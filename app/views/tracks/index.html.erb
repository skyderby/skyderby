<div class="tracks-index">
  <div class="tracks-index-header">
    <h1><%= t('application.header.tracks') %></h1>

    <div>
      <% activity = index_params[:kind] %>
      <%= link_to t('tracks.index.all'),
                  index_params.except(:kind),
                  class: ['tracks-index-activity-button', ('tracks-index-activity-button--active' unless activity)] %>

      <%= link_to 'Skydive',
                  index_params.merge(kind: 'skydive'),
                  class: ['tracks-index-activity-button', ('tracks-index-activity-button--active' if activity == 'skydive')] %>

      <%= link_to 'BASE',
                  index_params.merge(kind: 'base'),
                  class: ['tracks-index-activity-button', ('tracks-index-activity-button--active' if activity == 'base')] %>

      <%= link_to 'Speed',
                  index_params.merge(kind: 'speed_skydiving'),
                  class: ['tracks-index-activity-button', ('tracks-index-activity-button--active' if activity == 'speed_skydiving')] %>
    </div>
  </div>

  <%= render 'filters' %>

  <div class="content-block">
    <div class="row">
      <div class="col-sm-12">
        <div id="tracks-table" class="table table-hover">
          <div class="thead">
            <%= render 'table_header' %>
          </div>
          <div id="tracks-list" class="tbody">
            <%= render @tracks %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="tracks-pagination">
    <%= render 'tracks_pagination' %>
  </div>
</div>
