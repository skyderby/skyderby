<% provide :title, title(@track) %>

<% if @track.base? && @track.pro_view_available? %>
  <%= render 'tracks/base_jump' %>
<% elsif @track.skydive? && @track.pro_view_available? %>
  <%= render 'tracks/skydive_performance' %>
<% elsif @track.speed_skydiving? %>
  <%= render 'tracks/speed_skydiving' %>
<% else %>
  <%= render 'tracks/default' %>
<% end %>
