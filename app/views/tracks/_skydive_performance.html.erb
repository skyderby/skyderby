<% content_for :head do %>
  <meta name="track-kind" content="<%= @track.kind %>">
  <meta name="track-pro-view" content="true">
<% end %>

<div class="show-page">
  <%= render partial: 'header', locals: { track: @track } %>

  <div class="skydive-performance-page"
       data-controller="tracks--skydive-performance-track"
       data-tracks--skydive-performance-track-points-url-value="<%= track_points_path(@track, original_frequency: true, trimmed: { seconds_before_start: 5, seconds_after_end: 10 }) %>"
       data-tracks--skydive-performance-track-weather-url-value="<%= track_weather_data_path(@track) %>"
       data-tracks--skydive-performance-track-reference-point-url-value="<%= track_reference_point_path(@track) %>"
       data-tracks--skydive-performance-track-location-arrow-url-value="<%= asset_path('icons/location-arrow.svg') %>"
       data-tracks--skydive-performance-track-track-id-value="<%= @track.id %>"
       data-tracks--skydive-performance-track-charts-units-value="<%= Current.charts_units %>"
       data-tracks--skydive-performance-track-chart-settings-url-value="<%= track_chart_settings_path(@track) %>"
       <% if @compare_track %>
       data-tracks--skydive-performance-track-compare-points-url-value="<%= track_points_path(@compare_track, original_frequency: true, trimmed: { seconds_before_start: 5, seconds_after_end: 10 }) %>"
       data-tracks--skydive-performance-track-compare-weather-url-value="<%= track_weather_data_path(@compare_track) %>"
       data-tracks--skydive-performance-track-compare-track-name-value="<%= @compare_track.pilot&.name || @compare_track.name %>"
       <% end %>
       data-tracks--skydive-performance-track-tracks--range-selector-outlet="#range-selector"
       data-action="tracks--range-selector:change->tracks--skydive-performance-track#updateRange">

    <div class="card actions-bar skydive-performance-actions-bar" id="track-actions-bar">
      <div class="actions-bar-right">
        <div class="actions-bar-button skydive-performance-actions-bar__toggle">
          <div class="switch-container">
            <input type="checkbox"
                   id="straight-line-toggle"
                   class="switch-input"
                   data-tracks--skydive-performance-track-target="straightLineToggle"
                   data-action="tracks--skydive-performance-track#toggleStraightLine">
            <label for="straight-line-toggle" class="switch-label">
              <span class="switch-slider"></span>
              <span class="switch-text"><%= t('tracks.show.straight_line_distance') %></span>
            </label>
          </div>
        </div>

        <% if @compare_track %>
          <a href="<%= track_path(@track) %>" class="actions-bar-button skydive-performance-actions-bar__remove">
            <%= icon_tag 'xmark' %>
            <%= t('tracks.comparison.remove') %>
          </a>
        <% else %>
          <button type="button"
                  class="actions-bar-button"
                  data-action="tracks--skydive-performance-track#openCompareModal">
            <%= icon_tag 'right-left' %>
            <%= t('tracks.comparison.compare_button') %>
          </button>
        <% end %>

        <div class="skydive-performance-settings" data-controller="dropdown">
          <button class="actions-bar-button skydive-performance-settings__button"
                  popovertarget="skydive-performance-charts-menu"
                  type="button"
                  aria-label="<%= t('general.settings') %>">
            <%= icon_tag 'gear-solid' %>
          </button>

          <div id="skydive-performance-charts-menu" popover class="sd-dropdown-menu" data-dropdown-target="menu">
            <div class="dropdown-header"><%= t('tracks.show.menu_header') %></div>
            <button type="button"
                    class="dropdown-item"
                    data-mode="separate"
                    data-tracks--skydive-performance-track-target="chartsModeItem"
                    data-action="tracks--skydive-performance-track#setChartsMode">
              <%= t('tracks.show.menu_sep') %>
            </button>
            <button type="button"
                    class="dropdown-item"
                    data-mode="single"
                    data-tracks--skydive-performance-track-target="chartsModeItem"
                    data-action="tracks--skydive-performance-track#setChartsMode">
              <%= t('tracks.show.menu_one') %>
            </button>

            <div class="dropdown-divider"></div>

            <div class="dropdown-header"><%= t('tracks.show.units_header') %></div>
            <button type="button"
                    class="dropdown-item <%= 'active' if Current.charts_units.metric? %>"
                    data-units="metric"
                    data-tracks--skydive-performance-track-target="unitsItem"
                    data-action="tracks--skydive-performance-track#setUnits">
              <%= t('tracks.show.m_units_metric') %>
            </button>
            <button type="button"
                    class="dropdown-item <%= 'active' if Current.charts_units.imperial? %>"
                    data-units="imperial"
                    data-tracks--skydive-performance-track-target="unitsItem"
                    data-action="tracks--skydive-performance-track#setUnits">
              <%= t('tracks.show.m_units_imperial') %>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="track-show-content">
    <div class="skydive-performance-indicators-header">
      <%= render 'tracks/skydive_performance_indicators', data: { 'tracks--skydive-performance-track-target': 'summaryIndicators' } %>
      <% if @compare_track %>
        <%= render 'tracks/skydive_performance_indicators', compare: true, data: { 'tracks--skydive-performance-track-target': 'compareSummaryIndicators' } %>
      <% end %>
    </div>

    <%= render 'tracks/comparison_modal' %>

    <hr class="top-buffer">

    <div class="track-jump-range">
      <input id="range-selector" class="hidden" type="text" name="range" data-controller="tracks--range-selector" data-tracks--range-selector-step-value="5">

      <div class="range-shortcuts">
        <button class="button button--sm rounded hidden"
                data-tracks--skydive-performance-track-target="range3000to2000"
                data-action="tracks--skydive-performance-track#setRange"
                data-from="3000"
                data-to="2000">
          3000 — 2000<%= t('units.m') %>
        </button>
        <button class="button button--sm rounded hidden"
                data-tracks--skydive-performance-track-target="range2500to1500"
                data-action="tracks--skydive-performance-track#setRange"
                data-from="2500"
                data-to="1500">
          2500 — 1500<%= t('units.m') %>
        </button>
        <button class="button button--sm rounded"
                data-action="tracks--skydive-performance-track#resetRange">
          <%= t('tracks.show.full_jump') %>
        </button>

        <button class="button button--sm rounded best-window-shortcut hidden"
                data-tracks--skydive-performance-track-target="bestSpeed"
                data-action="tracks--skydive-performance-track#setRange">
          <span data-best-window-range></span><%= t('units.m') %>
          <span class="best-window-shortcut-value"><span data-best-window-value>—</span> <%= t('units.kmh') %></span>
        </button>
        <button class="button button--sm rounded best-window-shortcut hidden"
                data-tracks--skydive-performance-track-target="bestDistance"
                data-action="tracks--skydive-performance-track#setRange">
          <span data-best-window-range></span><%= t('units.m') %>
          <span class="best-window-shortcut-value"><span data-best-window-value>—</span> <%= t('units.m') %></span>
        </button>
        <button class="button button--sm rounded best-window-shortcut hidden"
                data-tracks--skydive-performance-track-target="bestTime"
                data-action="tracks--skydive-performance-track#setRange">
          <span data-best-window-range></span><%= t('units.m') %>
          <span class="best-window-shortcut-value"><span data-best-window-value>—</span> <%= t('units.sec') %></span>
        </button>
      </div>
    </div>

    <div class="skydive-performance-layout">
      <div class="skydive-performance-stage-tabs-row">
        <div class="seg skydive-performance-stage-tabs" role="tablist">
          <button type="button"
                  class="seg__btn"
                  data-stage="segments"
                  aria-pressed="true"
                  data-tracks--skydive-performance-track-target="stageTab"
                  data-action="tracks--skydive-performance-track#selectStage">
            <%= t('tracks.show.tab_segments') %>
          </button>
          <button type="button"
                  class="seg__btn"
                  data-stage="polar"
                  aria-pressed="false"
                  data-tracks--skydive-performance-track-target="stageTab"
                  data-action="tracks--skydive-performance-track#selectStage">
            <%= t('tracks.show.tab_drag_polar') %>
          </button>
          <button type="button"
                  class="seg__btn"
                  data-stage="map"
                  aria-pressed="false"
                  <%= 'disabled' if @compare_track %>
                  <% if @compare_track %>title="<%= t('tracks.show.map_unavailable_compare') %>"<% end %>
                  data-tracks--skydive-performance-track-target="stageTab"
                  data-action="tracks--skydive-performance-track#selectStage">
            <%= t('tracks.show.tab_map') %>
          </button>
        </div>
      </div>

      <div class="skydive-performance-stage">
        <div class="skydive-performance-side-panel">
          <div class="skydive-performance-segments-panel"
               data-tracks--skydive-performance-track-target="segmentsPanel">
            <div class="skydive-performance-segments"
                 data-tracks--skydive-performance-track-target="segmentsContent"></div>
          </div>

          <div class="skydive-performance-panel-content hidden"
               data-tracks--skydive-performance-track-target="panelContent">
            <div class="skydive-performance-polar-panel"
                 data-tracks--skydive-performance-track-target="polarPanel">
              <svg class="skydive-performance-polar"
                   data-tracks--skydive-performance-track-target="polarChart"
                   viewBox="0 0 1000 600"
                   preserveAspectRatio="xMidYMid meet">
              </svg>
            </div>

            <% unless @compare_track %>
              <div class="skydive-performance-map-panel hidden"
                   data-tracks--skydive-performance-track-target="mapPanel">
                <div class="skydive-performance-map-container">
                  <div class="skydive-performance-map"
                       data-tracks--skydive-performance-track-target="map">
                  </div>
                </div>

                <div class="switch-container">
                  <input type="checkbox"
                         id="designated-lane-toggle"
                         class="switch-input"
                         data-tracks--skydive-performance-track-target="designatedLaneToggle"
                         data-action="tracks--skydive-performance-track#toggleDesignatedLane">
                  <label for="designated-lane-toggle" class="switch-label">
                    <span class="switch-slider"></span>
                    <span class="switch-text"><%= t('tracks.show.designated_lane') %></span>
                  </label>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="skydive-performance-chart-container">
          <svg class="skydive-performance-chart"
               data-tracks--skydive-performance-track-target="sideProjection"
               viewBox="0 0 1000 600"
               preserveAspectRatio="xMidYMid meet">
            <g class="chart-grid" data-tracks--skydive-performance-track-target="grid"></g>
            <g class="chart-trajectory" data-tracks--skydive-performance-track-target="trajectory"></g>
          </svg>
          <div class="skydive-performance-empty-state hidden"
               data-tracks--skydive-performance-track-target="emptyState">
            <%= t('tracks.show.no_data') %>
          </div>
        </div>
      </div>

      <div class="skydive-performance-playback">
        <button class="skydive-performance-playback-button"
                data-tracks--skydive-performance-track-target="playButton"
                data-action="tracks--skydive-performance-track#togglePlay">
          <span class="icon-play"><%= icon_tag 'play-solid' %></span>
          <span class="icon-pause"><%= icon_tag 'pause-solid' %></span>
        </button>
        <input type="range"
               class="skydive-performance-playback-slider"
               min="0"
               max="100"
               value="0"
               data-tracks--skydive-performance-track-target="playbackSlider"
               data-action="input->tracks--skydive-performance-track#onSliderInput">
      </div>

      <div class="skydive-performance-indicators-row">
        <%= render 'tracks/playback_indicators', show_altitude_spent: false, data: { 'tracks--skydive-performance-track-target': 'playbackIndicators' } %>
        <% if @compare_track %>
          <%= render 'tracks/playback_indicators', show_altitude_spent: false, compare: true, data: { 'tracks--skydive-performance-track-target': 'comparePlaybackIndicators' } %>
        <% end %>
      </div>

      <div class="skydive-performance-charts"
           data-controller="synchronized-charts"
           data-action="mousemove->synchronized-charts#refreshTooltip touchmove->synchronized-charts#refreshTooltip touchstart->synchronized-charts#refreshTooltip mousemove->tracks--skydive-performance-track#onChartHover touchmove->tracks--skydive-performance-track#onChartHover">
        <div class="skydive-performance-separate-charts"
             data-tracks--skydive-performance-track-target="separateCharts">
          <div data-tracks--skydive-performance-track-target="glideChart"
               data-synchronized-charts-target="chart"></div>
          <div data-tracks--skydive-performance-track-target="speedChart"
               data-synchronized-charts-target="chart"></div>
          <div data-tracks--skydive-performance-track-target="altitudeDistanceChart"
               data-synchronized-charts-target="chart"></div>
          <div data-tracks--skydive-performance-track-target="sepChart"
               data-synchronized-charts-target="chart"></div>
        </div>
        <div class="skydive-performance-combined-chart hidden"
             data-tracks--skydive-performance-track-target="combinedChart"
             data-synchronized-charts-target="chart"></div>
      </div>
    </div>

    <blockquote class="flex flex-column">
      <%= render 'track_metadata' %>
    </blockquote>
    </div>
  </div>
</div>
