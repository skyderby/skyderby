<%# locals: (show_altitude_spent: true, compare: false, **attributes) %>

<div class="video-indicators<%= ' video-indicators--compare' if compare %>"
     data-controller="playback-indicators"
     <%= tag.attributes(attributes) %>>
  <div class="video-indicator-value-container">
    <div>
      <span class="video-indicator-value" data-playback-indicators-target="altitude">
        ---
      </span>
      <% if show_altitude_spent && !compare %>
        <span class="video-indicator-sub-value">
          <span data-playback-indicators-target="altitudeSpent">---</span>
          <%= icon_tag 'angle-down-solid' %>
        </span>
      <% end %>
      &nbsp;
      <span class="video-indicator-units"><%= t 'units.m' %></span>
    </div>
    <div class="video-indicator-title"><%= t 'tracks.indicators.altitude' %></div>
  </div>

  <div class="video-indicator-value-container">
    <div class="video-indicator-with-accel">
      <span class="video-indicator-value" data-playback-indicators-target="fullSpeed">
        ---
      </span>
      <% unless compare %>
        <div class="video-indicator-accel" data-playback-indicators-target="fullSpeedAccel">
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'minus-solid' %>
          <%= icon_tag 'angle-down-solid' %>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      <% end %>
      <span class="video-indicator-units"><%= t 'units.kmh' %></span>
    </div>
    <div class="video-indicator-title"><%= t 'tracks.indicators.full_speed' %></div>
  </div>

  <div class="video-indicator-value-container">
    <div class="video-indicator-with-accel">
      <span class="video-indicator-value" data-playback-indicators-target="hSpeed">
        ---
      </span>
      <% unless compare %>
        <div class="video-indicator-accel" data-playback-indicators-target="hSpeedAccel">
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'minus-solid' %>
          <%= icon_tag 'angle-down-solid' %>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      <% end %>
      <span class="video-indicator-units"><%= t 'units.kmh' %></span>
    </div>
    <div class="video-indicator-title"><%= t 'tracks.indicators.ground_speed' %></div>
  </div>

  <div class="video-indicator-value-container">
    <div class="video-indicator-with-accel">
      <span class="video-indicator-value" data-playback-indicators-target="vSpeed">
        ---
      </span>
      <% unless compare %>
        <div class="video-indicator-accel" data-playback-indicators-target="vSpeedAccel">
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'angle-up-solid' %>
          <%= icon_tag 'minus-solid' %>
          <%= icon_tag 'angle-down-solid' %>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      <% end %>
      <span class="video-indicator-units"><%= t 'units.kmh' %></span>
    </div>
    <div class="video-indicator-title"><%= t 'tracks.indicators.vertical_speed' %></div>
  </div>

  <div class="video-indicator-glide-container">
    <div class="video-indicator-value" data-playback-indicators-target="glideRatio">
      --.-
    </div>
    <svg class="video-indicator-angle" viewBox="0 0 240 240">
      <defs>
        <marker
          id="head<%= '-compare' if compare %>"
          orient="auto"
          markerWidth="3"
          markerHeight="4"
          refX="0.1"
          refY="2"
        >
          <path d="M0,0 V4 L2,2 Z" fill="var(--blue-grey-70)" />
        </marker>
      </defs>

      <path
        fill="transparent"
        stroke-width="20"
        stroke="var(--blue-90)"
        d=" M 0 20 A 100 100 0 0 1 0 220"
        />
      <path
        data-playback-indicators-target="angle"
        stroke="var(--blue-gray-80)"
        stroke-width="14"
        marker-end="url(#head<%= '-compare' if compare %>)"
        d="M 15 117 65 117"
        />
    </svg>

    <div class="video-indicator-title"><%= t 'tracks.indicators.glide_ratio' %></div>
  </div>
</div>
