<div class="container">
  <div class="page-header">
    <h1><%= t('.title') %></h1>
  </div>

  <%= form_for Track.new, html: { id: 'select-segment-form' } do |f| %>
    <%= f.hidden_field(:cache_id, value: @key) %>
    <input type="hidden" name="track[track_index]" id="track_track_index">
  <% end %>

  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t('.number') %></th>
        <th><%= t('.name') %></th>
        <th><%= t('.elev') %></th>
        <th><%= t('.pt_cnt') %></th>
      </tr>
    </thead>
    <tbody>
      <% @track_file.segments.each_with_index do |item, index| %>
        <tr class="track-segment-row" data-index="<%= index %>">
          <td class="text-info"><%= index %></td>
          <td class="text-info"><%= item[:name] %></td>
          <td>
            <p class="text-primary" style="display:inline"><%= item[:h_up] %>↑</p>
            <p class="text-success" style="display:inline"><%= item[:h_down] %>↓</p>
            <%= t('units.m') %>
          </td>
          <td class="text-info"><%= item[:points_count] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
