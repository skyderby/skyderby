<div class="modal-dialog modal-lg">
  <div class="modal-content">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal">
        <span aria-hidden="true">&times;</span>
        <span class="sr-only">Close</span>
      </button>
      <div class="row">
        <div class="col-sm-4">
          <h4 class="modal-title"><%= t('weather_datum.modal_title') %></h4>
        </div>
        <div class="col-sm-7">
          <div class="btn-group btn-group-xs" data-controller="dropdown">
            <button class="btn btn-default altitude-units" popovertarget="altitude-units-menu">
              <span>
                <%= "#{t('weather_datum.altitude_units')}: #{t('units.' + @weather_data.selected_units.altitude)}" %>
                <%= icon_tag 'angle-down-solid' %>
              </span>
            </button>

            <div id="altitude-units-menu" popover class="sd-dropdown-menu" data-dropdown-target="menu">
              <% @weather_data.altitude_units.each do |unit| %>
                <%= link_to t("units.#{unit}"), track_weather_data_path(@track, index_params.merge(altitude_unit: unit)), remote: true, class: class_names('dropdown-item', @weather_data.selected_units.altitude == unit && 'active') %>
              <% end %>
            </div>
          </div>
          <div class="btn-group btn-group-xs" data-controller="dropdown">
            <button class="btn btn-default wind-speed-units" popovertarget="wind-speed-units-menu">
              <span>
                <%= "#{t('weather_datum.wind_speed_units')}: #{t('units.' + @weather_data.selected_units.speed)}" %>
                <%= icon_tag 'angle-down-solid' %>
              </span>
            </button>

            <div id="wind-speed-units-menu" popover class="sd-dropdown-menu" data-dropdown-target="menu">
              <% @weather_data.speed_units.each do |unit| %>
                <%= link_to t("units.#{unit}"), track_weather_data_path(index_params.merge(wind_speed_unit: unit)), remote: true, class: class_names('dropdown-item', @weather_data.selected_units.speed == unit && 'active') %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-body">
      <%= render 'table' %>
    </div>
  </div>
</div>
