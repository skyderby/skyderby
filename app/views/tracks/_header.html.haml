.track-page-header
  .track-header
    .track-header__info
      - if track.pilot
        %a{href: profile_path(track.pilot)}
          %span{class: ['track-header-profile', ('contributor' if track.pilot.contributions.any?)]}
            = image_tag track.pilot.userpic_url(:thumb), class: 'track-header__photo loading-bg'
            = track.pilot.name
      - else
        %span.track-header-profile= track.name

      %span
        = t('tracks.show.title_suit') + ':'
        - if track.suit
          - manufacturer = track.suit.manufacturer
          %a{href: suit_path(track.suit)}
            = suit_presentation(track.suit)
        - else
          %span= track.missing_suit_name
      %span
        @
        - if track.place
          %a{href: place_path(track.place)}
            %span
            = place_presentation(track.place)
        - else
          %span= track.location

      - if track.unlisted_track?
        %i.fa.fa-eye-slash{'data-toggle': 'tooltip', title: t('visibility.unlisted')}
      - elsif track.private_track?
        %i.fa.fa-lock{'data-toggle': 'tooltip', title: t('visibility.private')}
    .track-header__id= "##{track.id}"

  .page-nav
    - controller_path = controller.controller_path
    = link_to track_path(track), class: ['page-tab', ('page-tab-active' if controller_path == 'tracks')] do
      %i.far.fa-chart-bar
      = t('tracks.show.charts')
    - if track.video
      = link_to track_video_path(track), class: ['page-tab', ('page-tab-active' if controller_path == 'tracks/videos')] do
        %i.far.fa-play-circle
        = 'Video'
    - elsif policy(track).edit?
      = link_to new_track_video_path(track), class: ['page-tab', ('page-tab-active' if controller_path == 'tracks/videos')] do
        %i.far.fa-play-circle
        = 'Video'
    - else
      %div.tooltip-wrapper{'data-toggle': 'tooltip', title: 'Pilot has not added video yet'}
        .page-tab
          %i.far.fa-play-circle
          = 'Video'
    - if track.ge_enabled
      = link_to track_globe_path(track), class: ['page-tab', ('page-tab-active' if controller.controller_path == 'tracks/globe')] do
        %i.far.fa-compass
        = '3D Maps'
    = link_to track_map_path(track), class: ['page-tab', ('page-tab-active' if controller_path == 'tracks/maps')] do
      %i.far.fa-compass
      = 'Google maps'
    = link_to track_results_path(@track),
              remote: true,
              class: 'page-tab',
              rel: 'nofollow' do
      %i.fas.fa-list
      = t('tracks.show.results')

    .page-nav-right
      - if track.skydive?
        = link_to t('events.show.weather_data'),
                 track_weather_data_path(@track),
                 remote: true,
                 class: 'page-tab',
                 rel: 'nofollow'

      - if policy(track).edit?
        %a.btn-flat.btn-tab{href: edit_track_path(track)}
          %i.fas.fa-pencil-alt
