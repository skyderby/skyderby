<button class="btn-flat same-padding dropdown-toggle" id="track-view-settings-dropdown" type="button" data-toggle="dropdown">
  <i class="fas fa-cog"></i>
  <%= t('general.settings') %>
</button>
<ul class="dropdown-menu dropdown-menu-right" role="menu" aria-labelledby="dropdownMenu1">
  <li class="dropdown-header" role="presentation">
    <%= t('tracks.show.menu_header') %>
  </li>
  <li class="<%= 'active' if Current.charts_mode.separate? %>" role="presentation">
    <%= link_to t('tracks.show.menu_sep'), show_params.except(:range).merge(charts_mode: 'separate'), remote: true, rel: 'nofollow' %>
  </li>
  <li class="<%= 'active' if Current.charts_mode.single? %>" role="presentation">
    <%= link_to t('tracks.show.menu_one'), show_params.except(:range).merge(charts_mode: 'single'), remote: true, rel: 'nofollow' %>
  </li>
  <li class="dropdown-header" role="presentation">
    <%= t('tracks.show.units_header') %>
  </li>
  <li class="<%= 'active' if Current.charts_units.metric? %>" role="presentation">
    <%= link_to t('tracks.show.m_units_metric'), show_params.except(:range).merge(charts_units: 'metric'), remote: true, rel: 'nofollow' %>
  </li>
  <li class="<%= 'active' if Current.charts_units.imperial? %>" role="presentation">
    <%= link_to t('tracks.show.m_units_imperial'), show_params.except(:range).merge(charts_units: 'imperial'), remote: true, rel: 'nofollow' %>
  </li>
</ul>
