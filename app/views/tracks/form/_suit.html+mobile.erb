<div class="form-group" data-controller="tracks--suit-field" data-mode="<%= mode_select_when ? 'select' : 'text' %>">
  <%= form.label :suit, t('activerecord.attributes.track.suit') %>
  <%= form.select :suit_id, suit_options, { include_blank: true }, class: 'form-control input-lg', 'data-controller': 'select2--suits', 'data-tracks--suit-field-target': 'select' %>
  <%= form.text_field :missing_suit_name, class: 'form-control input-lg', placeholder: t('tracks.form.suit_text_placeholder'), type: 'text', value: missing_suit_name, 'data-tracks--suit-field-target': 'text' %>
  <p class="help-block">
    <span data-tracks--suit-field-target="caption"></span>
    <a href="#" data-tracks--suit-field-target="link" data-action="tracks--suit-field#trigger"></a>
  </p>
</div>
