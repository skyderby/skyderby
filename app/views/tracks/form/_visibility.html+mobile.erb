<% visibility ||= recent_value(:visibility).presence || 'public_track' %>

<% if user_signed_in? %>
  <div class="form-group">
    <%= form.label :visibility, t('tracks.edit.visibility'), class: 'col-sm-3 control-label' %>
    <div class="col-sm-9">
      <%= form.select :visibility, track_visibility_options, { selected: visibility }, { class: 'form-control input-lg', 'data-controller': 'select2--local' } %>
    </div>
  </div>
<% end %>
