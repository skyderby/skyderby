<% activity ||= 'skydive' %>

<div class="form-group">
  <%= form.label :kind, t('activerecord.attributes.track.kind'), class: 'col-sm-3 control-label' %>
  <div class="btn-group col-sm-9" data-toggle="buttons">
    <label class="btn btn-default <%= 'active' if activity == 'skydive' %>">
      <%= form.radio_button :kind, 'skydive', checked: activity == 'skydive' %>
      Skydive
    </label>
    <label class="btn btn-default <%= 'active' unless activity == 'skydive' %>">
      <%= form.radio_button :kind, 'base', checked: activity != 'skydive' %>
      B.A.S.E
    </label>
  </div>
</div>
