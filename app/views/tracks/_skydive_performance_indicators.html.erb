<%# locals: (compare: false, **attributes) %>
<div class="track-indicators<%= ' track-indicators--compare' if compare %>"
     data-controller="summary-indicators"
     <%= tag.attributes(attributes) %>>
  <div class="track-indicator" data-value="distance">
    <div class="track-indicator-title"><%= t('tracks.indicators.distance') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="distance"
           data-summary-indicators-target="distance"></div>
      <div class="track-indicator-units" data-unit="length"><%= t("units.#{altitude_units_by_type(Current.charts_units)}") %></div>
    </div>

    <div class="wind-effect-container"
         style="display: none;"
         data-summary-indicators-target="windEffectContainerDistance">
      <div class="wind-effect-rail">
        <div class="wind-effect-result-percent"
             data-summary-indicators-target="windEffectDistancePercent"></div>
        <div class="wind-effect-wind-percent"
             data-summary-indicators-target="windEffectDistanceWindPercent"></div>
      </div>

      <div class="wind-effect-values">
        <div class="wind-effect-result"
             aria-label="wind cancelled value"
             data-summary-indicators-target="windEffectDistance"></div>
        <div class="wind-effect-wind"
             data-summary-indicators-target="windEffectDistanceWind"
             aria-label="wind effect"></div>
      </div>
    </div>
  </div>

  <div class="track-indicator" data-value="ground-speed">
    <div class="track-indicator-title"><%= t('tracks.indicators.ground_speed') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="average horizontal speed"
           data-summary-indicators-target="groundSpeed">
      </div>
      <div class="track-indicator-minmax-value">
        <div class="track-indicator-max">
          <span aria-label="maximum horizontal speed"
                data-summary-indicators-target="groundSpeedMax">
          </span>
          <%= icon_tag 'angle-up-solid' %>
        </div>
        <div class="track-indicator-min">
          <span aria-label="minimum horizontal speed"
                data-summary-indicators-target="groundSpeedMin">
          </span>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      </div>
      <div class="track-indicator-units" data-unit="speed"><%= t("units.#{speed_units_by_type(Current.charts_units)}") %></div>
    </div>

    <div class="wind-effect-container"
         style="display: none;"
         data-summary-indicators-target="windEffectContainerSpeed">
      <div class="wind-effect-rail">
        <div class="wind-effect-result-percent"
             data-summary-indicators-target="windEffectSpeedPercent"></div>
        <div class="wind-effect-wind-percent"
             data-summary-indicators-target="windEffectSpeedWindPercent"></div>
      </div>

      <div class="wind-effect-values">
        <div class="wind-effect-result"
             aria-label="wind cancelled value"
             data-summary-indicators-target="windEffectSpeed"></div>
        <div class="wind-effect-wind"
             data-summary-indicators-target="windEffectSpeedWind"
             aria-label="wind effect"></div>
      </div>
    </div>
  </div>

  <div class="track-indicator" data-value="glide-ratio">
    <div class="track-indicator-title"><%= t('tracks.indicators.glide_ratio') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="average glide ratio"
           data-summary-indicators-target="glideRatio">
      </div>
      <div class="track-indicator-minmax-value">
        <div class="track-indicator-max">
          <span aria-label="maximum glide ratio"
                data-summary-indicators-target="glideRatioMax"></span>
          <%= icon_tag 'angle-up-solid' %>
        </div>
        <div class="track-indicator-min">
          <span aria-label="minimum glide ratio"
                data-summary-indicators-target="glideRatioMin"></span>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      </div>
    </div>

    <div class="wind-effect-container"
         style="display: none;"
         data-summary-indicators-target="windEffectContainerGlideRatio">
      <div class="wind-effect-rail">
        <div class="wind-effect-result-percent"
             data-summary-indicators-target="windEffectGlideRatioPercent"></div>
        <div class="wind-effect-wind-percent"
             data-summary-indicators-target="windEffectGlideRatioWindPercent"></div>
      </div>

      <div class="wind-effect-values">
        <div class="wind-effect-result"
             aria-label="wind cancelled value"
             data-summary-indicators-target="windEffectGlideRatio"></div>
        <div class="wind-effect-wind"
             data-summary-indicators-target="windEffectGlideRatioWind"
             aria-label="wind effect"></div>
      </div>
    </div>
  </div>

  <div class="track-indicator" data-value="elevation">
    <div class="track-indicator-title"><%= t('tracks.indicators.elevation') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="elevation"
           data-summary-indicators-target="elevation"></div>
      <div class="track-indicator-units" data-unit="length"><%= t("units.#{altitude_units_by_type(Current.charts_units)}") %></div>
    </div>
  </div>

  <div class="track-indicator" data-value="vertical-speed">
    <div class="track-indicator-title"><%= t('tracks.indicators.vertical_speed') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="average vertical speed"
           data-summary-indicators-target="verticalSpeed">
      </div>

      <div class="track-indicator-minmax-value">
        <div class="track-indicator-min">
          <span aria-label="maximum vertical speed"
                data-summary-indicators-target="verticalSpeedMax">
          </span>
          <%= icon_tag 'angle-up-solid' %>
        </div>
        <div class="track-indicator-max">
          <span aria-label="minimum vertical speed"
                data-summary-indicators-target="verticalSpeedMin"></span>
          <%= icon_tag 'angle-down-solid' %>
        </div>
      </div>

      <div class="track-indicator-units" data-unit="speed"><%= t("units.#{speed_units_by_type(Current.charts_units)}") %></div>
    </div>
  </div>

  <div class="track-indicator" data-value="time">
    <div class="track-indicator-title"><%= t('tracks.indicators.duration') %></div>
    <div class="track-indicator-value-container">
      <div class="track-indicator-value"
           aria-label="duration"
           data-summary-indicators-target="duration"></div>
      <div class="track-indicator-units"><%= t('units.sec') %></div>
    </div>
  </div>
</div>
