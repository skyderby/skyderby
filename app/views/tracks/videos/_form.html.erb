<%= form_for @video,
             url: track_video_path,
             html: { class: 'form-horizontal',
                     'data-controller': 'tracks--video-form',
                     'data-action': 'youtube_api:ready@window->tracks--video-form#onYoutubeApiReady',
                     'data-url': track_video_chart_data_path(@video.track_id) } do |f| %>
  <div class="row">
    <div class="col-sm-4">
      <h3><%= t 'activerecord.attributes.track_videos.url' %></h3>
    </div>

    <div class="col-sm-8">
      <div class="url-group">
        <%= f.text_field :url,
                         class: 'form-control',
                         placeholder: t('.url_placeholder'),
                         'data-tracks--video-form-target': 'url',
                         'data-action': 'change->tracks--video-form#onChangeUrl input->tracks--video-form#onChangeUrl' %>
      </div>
      <%= f.hidden_field :video_code %>
      <%= f.hidden_field :track_id %>
    </div>
  </div>

  <hr>

  <div class="row">
    <div class="col-sm-4">
      <h3><%= t 'activerecord.attributes.track_videos.video_offset' %></h3>
      <p><%= t '.video_offset_description' %></p>
    </div>
    <div class="col-sm-8">
      <div data-tracks--video-form-target="player"></div>
    </div>
    <div class="col-sm-3 col-sm-offset-4 top-buffer">
      <div class="input-group">
        <%= f.text_field :video_offset, class: 'form-control text-center', 'data-tracks--video-form-target': 'videoOffset' %>
        <button class="button" data-action="click->tracks--video-form#setVideoOffset"><%= t '.set' %></button>
      </div>
    </div>
  </div>

  <hr>

  <div class="row">
    <div class="col-sm-4">
      <h3><%= t 'activerecord.attributes.track_videos.track_offset' %></h3>
      <p><%= t '.track_offset_description' %></p>
    </div>
    <div class="col-sm-8">
      <div id="chart" data-tracks--video-form-target="chart"></div>
    </div>
    <div class="col-sm-3 col-sm-offset-4">
      <div class="input-group">
        <button class="button" data-action="click->tracks--video-form#decreaseTrackOffset">
          <%= icon_tag 'angle-left-solid' %>
        </button>
        <%= f.text_field :track_offset, class: 'form-control text-center', 'data-tracks--video-form-target': 'trackOffset' %>
        <button class="button" data-action="click->tracks--video-form#increaseTrackOffset">
          <%= icon_tag 'angle-right-solid' %>
        </button>
      </div>
    </div>
  </div>

  <div class="row top-buffer-30">
    <div class="col-sm-4 col-sm-offset-4">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
    </div>
    <div class="col-sm-4 text-right">
      <%= link_to t('general.delete'),
                  track_video_path,
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this video?' },
                  class: 'button' %>
    </div>
  </div>
<% end %>
