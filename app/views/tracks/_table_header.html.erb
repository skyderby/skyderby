<% params_order = (index_params[:order] || '').split(' ') %>
<% order_field = (params_order[0] || 'id').upcase %>
<% order_direction = (params_order[1] || 'DESC').upcase %>

<tr>
  <th>
    <%= t 'activerecord.attributes.track.id' %>
    <%= tracks_sort_header(order_field, order_direction, 'id', 'ID') %>
  </th>
  <th><%= t 'activerecord.attributes.track.name' %></th>
  <th><%= t 'activerecord.attributes.track.suit' %></th>
  <th><%= t 'activerecord.attributes.track.place' %></th>
  <th><%= t 'activerecord.attributes.track.comment' %></th>
  <th class="result-head text-right">
    <%= t 'disciplines.distance' %>
    <%= tracks_sort_header(order_field, order_direction, 'distance', 'Distance') %>
  </th>
  <th class="result-head text-right">
    <%= t 'disciplines.speed' %>
    <%= tracks_sort_header(order_field, order_direction, 'speed', 'Speed') %>
  </th>
  <th class="result-head text-right">
    <%= t 'disciplines.time' %>
    <%= tracks_sort_header(order_field, order_direction, 'time', 'Time') %>
  </th>
  <th>
    <%= t 'activerecord.attributes.track.recorded_at' %>
    <%= tracks_sort_header(order_field, order_direction, 'recorded_at', 'Recorded at') %>
  </th>
  <th></th>
</tr>
