<div class="dashboard">
  <div class="dashboard-block">
    <h2 class="dashboard-block-title">
      <%= link_to 'Donations', donations_path %>
    </h2>
    <div class="dashboard-indicator">
      <div class="dashboard-value"><%= @dashboard.last_year_donations %>$</div>
      <div class="dashboard-label">in past year</div>
    </div>
    <div class="dashboard-indicator">
      <div class="dashboard-value"><%= @dashboard.last_30_days_donations %>$</div>
      <div class="dashboard-label">in past 30 days</div>
    </div>
    <div class="dashboard-chart" data-controller="donation-stats">
      <script type="application/json" data-donation-stats-target="data">
        <%= raw render partial: 'static_pages/donation_stats',
                       locals: { donations: @dashboard.donation_stats },
                       formats: [:json] %>
      </script>
      <div data-donation-stats-target="chart"></div>
    </div>
  </div>
</div>
