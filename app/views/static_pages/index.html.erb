<% if @dashboard %>
  <%= render 'static_pages/dashboard', dashboard: @dashboard %>
<% else %>
  <% content_for :description, t('static_pages.landing.meta_description') %>

  <% content_for :og_image do %>
    <meta property="og:image" content="<%= asset_url('landing/og_cover.png') %>">
    <meta property="og:image:secure_url" content="<%= asset_url('landing/og_cover.png') %>">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="twitter:card" content="summary_large_image">
  <% end %>

  <% content_for :head do %>
    <meta name="color-scheme" content="light dark">
  <% end %>

  <div class="lp">
    <%= render 'static_pages/landing/hero', page: @page %>
    <%= render 'static_pages/landing/stats', page: @page %>
    <%= render 'static_pages/landing/showcase' %>
    <%= render 'static_pages/landing/leaderboard' %>
    <%= render 'static_pages/landing/pro_view_upsell' %>
    <%= render 'static_pages/landing/founder' %>
  </div>
<% end %>
