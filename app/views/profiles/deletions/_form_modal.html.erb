<%= form_with scope: :profile_deletion, url: profile_deletion_path(@profile),
              data: { controller: 'modal-form', action: 'form:submit-success->dialog#close' } do |f| %>
  <div class="sd-form">
    <p>
      <%= t('profiles.deletions.form_modal.confirmation_html', name: tag.b(@profile.name)) %>
    </p>

    <% if @profile.belongs_to_user? %>
      <div class="grid">
        <span class="form-label col-4"><%= t('profiles.deletions.form_modal.user_email') %></span>
        <div class="form-input col-8"><%= @profile.owner.email %></div>
      </div>

      <div class="grid">
        <div class="col-4"></div>
        <div class="col-8">
          <label class="checkbox-label">
            <%= f.check_box :delete_user %>
            <%= t('profiles.deletions.form_modal.delete_user') %>
          </label>
        </div>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit t('general.delete'), class: 'button button--danger' %>
      <button type="button" class="button" data-action="dialog#close"><%= t 'general.cancel' %></button>
    </div>
  </div>
<% end %>
