<turbo-frame id="hot-select-contributor">
  <div class="hot-select-options">
    <% @profiles.each do |profile| %>
      <div class="hot-select-option" data-value="<%= profile.id %>" data-action="click->hot-select#choose">
        <%= profile.name %>
      </div>
    <% end %>
  </div>
</turbo-frame>
