<% provide :title, @profile.name if @profile.name.present? %>

<div class="show-page">
  <%= render 'profiles/header', profile: @profile %>

  <div class="show-page-content">
    <div class="card">
      <div class="profile-achievements">
        <div class="profile-section-header">
          <%= t('.achievements') %>
          <% if policy(:badge).create? %>
            <%= link_to new_profile_badge_path(@profile), class: 'default-button', data: { turbo_stream: true } do %>
              <%= svg_icon 'plus-solid' %>
              Add
            <% end %>
          <% end %>
        </div>
        <div class="profile-badges" id="profile-badges">
          <% if @profile.badges.any? %>
            <%= render partial: 'profiles/badges/badge', collection: @profile.badges, as: :badge %>
          <% else %>
            <div class="blankslate">
              <h3><%= t('.no_badges', name: @profile.name) %></h3>
            </div>
          <% end %>
        </div>
      </div>

      <div class="profile-section">
        <div class="profile-section-header">
          <%= t('.online_competitions') %>
        </div>
        <div class="profile-rankings">
          <% if @profile.ranking_positions.any? %>
            <%= render partial: 'profiles/ranking_position', collection: @profile.ranking_positions, as: :position %>
          <% else %>
            <div class="blankslate">
              <h3><%= t('.no_rankings', name: @profile.name) %></h3>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
