<div class="achievement">
  <div class="achievement__icon <%= "achievement--#{badge.category}" %> <%= "achievement--#{badge.kind}" if badge.kind %>">
    <% case badge.category %>
    <% when 'sponsor' %>
      <%= svg_icon 'dollar-sign-solid' %>
    <% when 'special' %>
      <%= svg_icon 'fire-solid' %>
    <% when 'competition' %>
      <%= svg_icon 'trophy-solid' %>
    <% when 'online' %>
      <%= svg_icon 'star-solid' %>
    <% when 'skyderby' %>
      <%= svg_icon 'rocket-outline' %>
    <% end %>
  </div>
  <div class="achievement__text <%= 'achievement--no-subtext' unless badge.comment.present? %>">
    <%= badge.name %>
    <% if badge.comment %>
      <span><%= badge.comment %></span>
    <% end %>
  </div>
  <div class="achievement__top"></div>
  <div class="achievement__bottom"></div>
</div>
