<% provide :title, t('.title') %>

<div class="success-page">
  <div class="confetti-container">
    <% 50.times do |i| %>
      <div class="confetti confetti--<%= i % 6 %>" style="--delay: <%= rand(0..3000) %>ms; --x: <%= rand(0..100) %>vw; --drift: <%= rand(-50..50) %>px;"></div>
    <% end %>
  </div>

  <div class="success-content">
    <div class="success-badge">
      <%= svg_icon 'trophy-solid' %>
    </div>

    <h1 class="success-title"><%= t('.title') %></h1>
    <p class="success-subtitle"><%= t('.subtitle') %></p>

    <div class="success-features">
      <h3 class="success-features__title"><%= t('.unlocked_title') %></h3>
      <ul class="success-features__list">
        <li>
          <%= svg_icon 'check-solid' %>
          <span><strong>BASE Pro View</strong> — <%= t('.feature_base') %></span>
        </li>
        <li>
          <%= svg_icon 'check-solid' %>
          <span><strong>Skydive Pro View</strong> — <%= t('.feature_skydive') %></span>
        </li>
        <li>
          <%= svg_icon 'check-solid' %>
          <span><strong><%= t('.feature_highlight_name') %></strong> — <span class="contributor"><%= current_user.name %></span></span>
        </li>
        <li>
          <%= svg_icon 'check-solid' %>
          <span><strong>Pro Compare</strong> — <%= t('.feature_compare') %></span>
        </li>
      </ul>
    </div>

    <div class="success-actions">
      <%= link_to t('.explore_tracks'), root_path, class: 'button button--primary success-actions__primary' %>
      <%= button_to t('.manage_subscription'), billing_portal_subscriptions_path, method: :post, class: 'button success-actions__secondary', data: { turbo: false } %>
    </div>
  </div>
</div>
