!!! 5
%html
  %head
    = render 'layouts/head'

    = stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload'
    = stylesheet_link_tag 'desktop/application', media: 'all', 'data-turbo-track': 'reload'

  %body
    #modal-root
    #wrap{class: yield(:wrapper_classes)}
      = render 'layouts/header'
      = render template: 'announcements/active'

      .toast-container#toasts
        - flash.each do |type, message|
          = render 'toasts/toast', type: type, message: message

      = yield
      -# Modal for Backbone Views
      .modal.fade#modal{tabindex: '-1', role: 'dialog', aria: {labelledby: 'myModalLabel', hidden: 'true'}}

      -# new track modal
      = render partial: 'track_files/new_modal'

    = render 'errors/ajax_error_message'
    = render 'layouts/footer'

    = yield :page_js
