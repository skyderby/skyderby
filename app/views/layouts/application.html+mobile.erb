!!! 5
%html
  %head
    = render 'layouts/head'
    = stylesheet_link_tag 'mobile/application', 'data-turbo-track': 'reload'

    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"}

  %body
    #modal-root
    = render 'layouts/header' unless mobile_app?
    = render template: 'announcements/active' unless controller.controller_path == 'static_pages'

    .toast-container#toasts
      - flash.each do |type, message|
        = render 'toasts/toast', type: type, message: message

    = yield
    -# Modal for Backbone Views
    .modal.fade#modal{tabindex: '-1', role: 'dialog', aria: {labelledby: 'myModalLabel', hidden: 'true'}}

    = render 'errors/ajax_error_message'
    = render 'layouts/footer'

    = yield :page_js
