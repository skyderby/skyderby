= link_to root_path, class: 'nav-brand' do
  %span Skyderby

%ul.nav-menu
  - root_controller = controller.controller_path.split('/').first
  %li.nav-menu-item{class: ('nav-menu-item--active' if root_controller == 'tracks')}
    = link_to t('application.header.tracks'), tracks_path
  %li.nav-menu-item{class: ('nav-menu-item--active' if ['events', 'tournaments'].include? root_controller)}
    = link_to t('application.header.competitions'), events_path
  %li.nav-menu-item{class: ('nav-menu-item--active' if root_controller == 'virtual_competitions')}
    = link_to t('application.header.online_competitions'), virtual_competitions_path
  %li.nav-menu-item{class: ('nav-menu-item--active' if root_controller == 'places')}
    = link_to t('application.header.places'), places_path
