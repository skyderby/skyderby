<% if Rails.env.production? %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DZJHMMLQ5M"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-DZJHMMLQ5M');
  </script>
<% elsif Rails.env.development? %>
  <script>
    function gtag() {
      const params = Array.prototype.slice.call(arguments, gtag.length);
      console.log("GTag: " + JSON.stringify(params));
    };
  </script>
<% else %>
  <script>
    function gtag() {};
  </script>
<% end %>
