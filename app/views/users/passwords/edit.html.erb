<div class="container">
  <h2><%= t('devise.passwords.edit.change_your_password') %></h2>

  <%= form_for(:user, url: user_password_path, html: { method: :put, class: 'change-password' }) do |f| %>
    <%= devise_error_messages! %>
    <%= f.hidden_field :reset_password_token %>

    <div class="form-row">
      <%= f.label :password, t('devise.passwords.edit.new_password'), class: 'col-sm-2 form-label' %>
      <div class="col-sm-6">
        <%= f.password_field :password, autocomplete: 'off', class: 'form-input' %>
      </div>
    </div>

    <div class="form-row">
      <%= f.label :password_confirmation, t('devise.passwords.edit.confirm_new_password'), class: 'col-sm-2 form-label' %>
      <div class="col-sm-6">
        <%= f.password_field :password_confirmation, autocomplete: 'off', class: 'form-input' %>
      </div>
    </div>

    <div class="form-row">
      <div class="col-sm-6 col-sm-offset-2">
        <%= f.submit t('devise.passwords.edit.change_my_password'), class: 'button button--primary' %>
      </div>
    </div>

    <div class="form-row">
      <div class="col-sm-6 col-sm-offset-2">
        <%= render 'users/shared/links' %>
      </div>
    </div>
  <% end %>
</div>
