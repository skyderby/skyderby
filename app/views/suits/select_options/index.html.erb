<turbo-frame id="<%= sanitize params[:frame_id] %>">
  <div class="hot-select-options">
    <% @suits.each do |suit| %>
      <div class="hot-select-option" data-value="<%= suit.id %>">
        <%= suit_presentation suit %>
      </div>
    <% end %>

    <% if @suits.total_pages > @suits.current_page %>
      <% next_page = @suits.current_page + 1 %>
      <% frame_id = "#{sanitize params[:frame_id]}-#{next_page}" %>
      <%= render 'hot_select/load_more', page: next_page, frame_id: %>
    <% end %>
  </div>
</turbo-frame>
