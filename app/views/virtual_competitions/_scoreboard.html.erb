<div class="online-competition__scoreboard">
  <% if @competition.all_scores.size > 2 %>
    <%= render 'leaderboard', leaders: @competition.all_scores.take(3) %>
  <% end %>

  <div class="row">
    <div class="col-sm-12">
      <table class="table vc-scoreboard-table">
        <thead>
          <tr>
            <th>#</th>
            <th><%= t 'activerecord.attributes.track.name' %></th>
            <th><%= t 'activerecord.attributes.track.suit' %></th>
            <% if @competition.worldwide? %>
              <th><%= t 'activerecord.attributes.track.place' %></th>
            <% end %>
            <th class="text-right"><%= t('.result') %></th>
            <% if @competition.display_highest_speed %>
              <th class="text-right">Best speed</th>
            <% end %>
            <% if @competition.display_highest_gr %>
              <th class="text-right">Best G/R</th>
            <% end %>
            <th class="text-right"><%= t 'activerecord.attributes.track.recorded_at' %></th>
            <th></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @competition.scores.each do |score| %>
            <tr data-rank="<%= score.rank %>">
              <td><%= score.rank %></td>
              <td>
                <%= link_to profile_path(score.profile), class: 'dotted-underline' do %>
                  <span class="<%= 'contributor' if score.profile.contributor? %>">
                    <%= score.profile.name.titleize %>
                  </span>
                <% end %>
              </td>
              <td><%= suit_presentation(score.suit) %></td>
              <% if @competition.worldwide? %>
                <td><%= track_place(score.track) %></td>
              <% end %>
              <td class="text-right">
                <%= link_to format_result(score.result, @competition), score.track, class: 'dotted-underline' %>
              </td>
              <% if @competition.display_highest_speed %>
                <td class="text-right"><%= (score.highest_speed || 0.0).round(1) %></td>
              <% end %>
              <% if @competition.display_highest_gr %>
                <td class="text-right"><%= (score.highest_gr || 0.0).round(2) %></td>
              <% end %>
              <td class="text-right"><%= score.recorded_at&.strftime('%d.%m.%Y') %></td>
              <td>
                <%= link_to virtual_competition_person_details_path(@competition, profile_id: score.profile), remote: true do %>
                  <i class="fa fa-list text-muted"></i>
                <% end %>
              </td>
              <td>
                <% if score.track.video %>
                  <i class="fa fa-video"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="text-center">
        <%= will_paginate @competition.scores, renderer: BootstrapPagination::Rails %>
      </div>
    </div>
  </div>
</div>
