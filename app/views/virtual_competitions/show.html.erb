<% provide :title, @competition.title %>
<% editable = policy(@competition).edit? %>

<div class="show-page">
  <div class="show-page-header">
    <h1 class="show-page-title"><%= @competition.title %></h1>
    <div class="show-page-info">
      <div>
        <%= t('virtual_competitions.place') %>
        <% if @competition.place %>
          <%= place_presentation(@competition.place) %>
        <% else %>
          <%= t('virtual_competitions.worldwide') %>
        <% end %>
      </div>
      <div><%= competition_suit(@competition) %></div>
      <div><%= competition_task(@competition) %></div>
    </div>

    <%= render 'navbar', editable: %>
  </div>

  <div class="show-page-content">
    <% current_params = request.path_parameters.merge(request.query_parameters.symbolize_keys) %>
    <div class="ranking-filters">
      <% if @ranking.jump_kind_options.any? %>
        <div class="tab-bar tab-bar--jump-kind">
          <% @ranking.jump_kind_options.each do |kind| %>
            <%= link_to t(".jump_kinds.#{kind || 'all'}"),
                        url_for(current_params.merge(jump_kind: kind, page: nil)),
                        class: class_names('tab-bar-item', 'active' => @ranking.jump_kind == kind) %>
          <% end %>
        </div>
      <% end %>

      <div class="tab-bar tab-bar--gender">
        <% @ranking.gender_options.each do |gender| %>
          <%= link_to t(".genders.#{gender || 'open'}"),
                      url_for(current_params.merge(gender: gender, page: nil)),
                      class: class_names('tab-bar-item', 'active' => @ranking.gender == gender) %>
        <% end %>
      </div>
    </div>

    <div class="card">
      <%= render 'scoreboard', ranking: @ranking %>
    </div>

    <%= render 'sponsors/list', sponsorable: @competition, editable: %>
  </div>
</div>
