<div class="online-competition-winner">
  <div class="online-competition-winner__photo">
    <%= image_tag result.profile.userpic_url(:medium) %>
  </div>
  <div class="online-competition-winner__caption">
    <%= link_to result.profile.name.titleize, profile_path(result.profile), 'data-toggle' => 'tooltip', title: t('virtual_competitions.scoreboard.show_profile'), class: 'online-competition-winner__name' %>
    <%= link_to track_path(result.track_id), 'data-toggle' => 'tooltip', title: t('virtual_competitions.scoreboard.show_details'), class: 'online-competition-winner__result' do %>
      <span class="online-competition-winner__result-value"><%= format_result(result.result, result.virtual_competition) %></span>
      <span class="online-competition-winner__result-unit"><%= competition_unit(result.virtual_competition) %></span>
    <% end %>
  </div>
</div>
