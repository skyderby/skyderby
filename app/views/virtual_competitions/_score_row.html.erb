<%# locals: (score:, ranking:, current_user_row: false) %>

<% competition = ranking.competition %>
<% rank_change = ranking.rank_change_for(score) %>
<% on_podium = score.rank <= 3 %>

<div class="<%= class_names('vc-scoreboard__row', on_podium && "vc-scoreboard__row--place-#{score.rank}", current_user_row && 'vc-scoreboard__row--current') %>"
     data-rank="<%= score.rank %>"
     data-virtual-competitions--compare-target="row"
     data-action="click->virtual-competitions--compare#selectRow"
     data-track-id="<%= score.track.id %>"
     data-pilot="<%= score.profile.name.titleize %>"
     data-result="<%= "#{format_result(score.result, competition)} #{competition_unit(competition)}" %>"
     data-kind="<%= score.track.kind %>">
  <div class="vc-scoreboard__rank">
    <span class="<%= class_names('vc-scoreboard__rank-number', on_podium && "rank-badge rank-badge--#{score.rank}") %>"><%= score.rank %></span>
    <%= icon_tag 'check-solid', class: 'vc-scoreboard__rank-check' %>
  </div>
  <% if ranking.show_rank_changes? %>
    <div class="vc-scoreboard__rank-change">
      <% if rank_change.nil? %>
        <span class="rank-new" data-controller="tooltip">•<span class="for-screen-reader"><%= t('virtual_competitions.scoreboard.rank_new') %></span></span>
      <% elsif rank_change.positive? %>
        <span class="rank-up" data-controller="tooltip">▲<span class="for-screen-reader"><%= t('virtual_competitions.scoreboard.rank_up', change: rank_change) %></span></span>
      <% elsif rank_change.negative? %>
        <span class="rank-down" data-controller="tooltip">▼<span class="for-screen-reader"><%= t('virtual_competitions.scoreboard.rank_down', change: rank_change.abs) %></span></span>
      <% end %>
    </div>
  <% end %>

  <div class="vc-scoreboard__main">
    <div class="vc-scoreboard__name">
      <%= link_to profile_path(score.profile), class: 'dotted-underline' do %>
        <span class="<%= 'contributor' if score.profile.contributor? %>">
          <%= score.profile.name.titleize %>
        </span>
      <% end %>
    </div>
    <div class="vc-scoreboard__meta">
      <% if score.suit %>
        <span class="vc-scoreboard__suit">
          <%= icon_tag 'wingsuit' %>
          <%= suit_presentation(score.suit) %>
        </span>
      <% end %>
      <% if competition.worldwide? %>
        <span class="vc-scoreboard__place">
          <%= icon_tag 'location-dot-solid' %>
          <%= track_place(score.track) %>
        </span>
      <% end %>
    </div>
  </div>

  <div class="vc-scoreboard__stats">
    <% if competition.display_highest_speed %>
      <div class="vc-scoreboard__stat vc-scoreboard__stat--speed">
        <span class="vc-scoreboard__stat-label">Speed</span>
        <span class="vc-scoreboard__stat-value"><%= (score.highest_speed || 0.0).round(1) %></span>
      </div>
    <% end %>
    <% if competition.display_highest_gr %>
      <div class="vc-scoreboard__stat vc-scoreboard__stat--gr">
        <span class="vc-scoreboard__stat-label">G/R</span>
        <span class="vc-scoreboard__stat-value"><%= (score.highest_gr || 0.0).round(2) %></span>
      </div>
    <% end %>
  </div>

  <div class="vc-scoreboard__video">
    <% if score.track.video %>
      <%= icon_tag 'play-solid' %>
    <% end %>
  </div>

  <div class="vc-scoreboard__result">
    <%= link_to score.track, class: 'vc-scoreboard__result-link' do %>
      <span class="vc-scoreboard__result-value"><%= format_result(score.result, competition) %></span>
      <span class="vc-scoreboard__result-unit"><%= competition_unit(competition) %></span>
    <% end %>
  </div>

  <div class="vc-scoreboard__date">
    <%= score.recorded_at&.strftime('%d.%m.%Y') %>
  </div>

  <div class="vc-scoreboard__actions">
    <%= link_to virtual_competition_person_details_path(competition, profile_id: score.profile),
                class: 'vc-scoreboard__action', data: { turbo_stream: true } do %>
      <%= icon_tag 'list-ul-solid' %>
    <% end %>
  </div>
</div>
