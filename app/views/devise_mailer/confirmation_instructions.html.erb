<table border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding-bottom: 24px;">
      <span style="font-size: 20px; font-weight: 600; color: #1a1a1a;">
        Welcome to Skyderby!
      </span>
    </td>
  </tr>

  <tr>
    <td style="padding-bottom: 24px; font-size: 15px; color: #4a4a4a; line-height: 1.6;">
      Thanks for creating an account. Please confirm your email address by clicking the button below.
    </td>
  </tr>

  <tr>
    <td align="center" style="padding-bottom: 32px;">
      <a href="<%= confirmation_url(@resource, confirmation_token: @token) %>" style="display: inline-block; background-color: #3b82f6; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 12px 32px; border-radius: 8px;">
        Confirm email address
      </a>
    </td>
  </tr>

  <tr>
    <td style="font-size: 14px; color: #6b7280; line-height: 1.5;">
      If you didn't create this account, you can safely ignore this email.
    </td>
  </tr>
</table>
