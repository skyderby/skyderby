<% can_update ||= false %>
<% result_class ||= '' %>

<td class="<%= class_names 'scoreboard-result', result_class %>">
  <% if result.valid? %>
    <%= result.formated %>
    <% if result.penalized? && result.apply_penalty_to_result? %>
      <sup class="text-danger">-<%= result.penalty_size %>%</sup>
    <% end %>
  <% elsif can_update %>
    <i class="far fa-question-circle text-danger"></i>
  <% end %>
  <span>
    <%= link_to(performance_competition_result_path(event, event_track), class: 'show-result', rel: 'nofollow') do %>
      <i class="<%= can_update ? 'fas fa-pencil-alt' : 'fa fa-search' %>"></i>
    <% end %>
  </span>
</td>
