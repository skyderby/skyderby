<% url = @competitor.new_record? ?
           boogie_competitors_path(@event) :
           boogie_competitor_path(@event, @competitor) %>

<%= form_with model: @competitor, url:, scope: :competitor,
              data: { controller: 'modal-form', action: 'form:submit-success->dialog#close' } do |f| %>
  <div class="sd-form">
    <h3 class="form-section-title">
      <%= t('competitors.form.profile') %>
    </h3>

    <%= render 'competitors/profile_fields', f:, competitor: @competitor, event: @event %>

    <div class="form-divider"></div>

    <h3 class="form-section-title">
      <%= t('competitors.form.suit_and_category') %>
    </h3>

    <div class="grid">
      <%= f.label :suit_id, class: 'form-label col-4' %>
      <% options = @competitor.suit_id ? options_for_select([[@competitor.suit_name, @competitor.suit_id]], @competitor.suit_id) : [] %>
      <%= render 'hot_select/select', form: f, name: :suit_id, src: suits_select_options_path, options:, class: 'col-8' %>
    </div>

    <div class="grid">
      <%= f.label :section_id, class: 'form-label col-4' %>
      <% options = options_from_collection_for_select(@event.categories, :id, :name, @competitor.section_id) %>
      <%= render 'hot_select/local_select', form: f, name: :section_id, options:, class: 'col-8', hide_clear_button: true %>
    </div>

    <div class="form-actions">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
      <button type="button" class="button" data-action="dialog#close"><%= t 'general.cancel' %></button>
    </div>
  </div>
<% end %>
