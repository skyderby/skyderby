<%# locals(event:, competitor:, editable:) %>

<td class="competitor">
  <%= link_to profile_path(competitor.profile), class: 'competitor-profile' do %>
    <%= competitor.name.titleize %>
    <% if competitor.assigned_number.present? %>
      <span class="assigned-number">#<%= competitor.assigned_number %></span>
    <% end %>
  <% end %>

  <div class="competitor-suit text-gray">
    <%= competitor.suit.manufacturer_code %>
    <%= competitor.suit_name %>
  </div>

  <% if editable %>
    <div class="cell-actions">
      <div class="sd-dropdown" data-controller="dropdown">
        <button class="dropdown-toggle button button--ghost button--sm" data-action="click->dropdown#toggle">
          <%= icon_tag 'ellipsis-vertical-solid' %>
        </button>

        <template data-dropdown-target="menu">
          <div class="sd-dropdown-menu">
            <%= button_to edit_boogie_competitor_path(event, competitor),
                          class: 'dropdown-item',
                          method: :get,
                          form: { data: { turbo_stream: true } } do %>
              <%= t('general.edit') %>
            <% end %>

            <%= button_to boogie_competitor_path(event, competitor),
                          class: 'dropdown-item',
                          method: :delete,
                          form: { data: { turbo_stream: true, confirm: t('general.confirm_delete') } } do %>
              <%= t('general.delete') %>
            <% end %>
          </div>
        </template>
      </div>
    </div>
  <% end %>
</td>

<td class="text-center">
  <% russia_restricted = event.is_official && [2020, 2021].include?(event.starts_at.year) %>
  <% if russia_restricted && competitor.country_code == 'RUS' %>
    <span data-toggle="tooltip" title="Neutral Athletes">RPF</span>
  <% else %>
    <span data-toggle="tooltip" title="<%= competitor.country_name %>"><%= competitor.country_code %></span>
  <% end %>
</td>
