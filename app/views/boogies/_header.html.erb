<% editable ||= false %>

<div class="show-page-header">
  <h1 class="show-page-title">
    <%= @event.name %>
    <small>
      <% if @event.unlisted_event? %>
        <i class="fa fa-eye-slash" data-toggle="tooltip" title="<%= t('visibility.unlisted') %>"></i>
      <% elsif @event.private_event? %>
        <i class="fa fa-lock" data-toggle="tooltip" title="<%= t('visibility.private') %>"></i>
      <% end %>
    </small>
  </h1>
  <div class="show-page-info">
    <%= svg_icon 'location-dot-solid' %>
    <%= place_presentation(@event.place) %>
    <% if @event.place_msl %>
      <span>(MSL: <%= @event.place_msl %> <%= t('units.m') %>)</span>
    <% end %>
  </div>
  <div class="show-page-info">
    <%= "#{t('events.show.comp_window')}: #{@event.range_from} - #{@event.range_to} #{t('units.m')}" %>
  </div>

  <div class="page-nav">
    <% controller_path = controller.controller_path %>
    <%= link_to boogie_path(@event), class: ['page-tab', ('page-tab-active' if controller_path == 'boogies' && action_name == 'show')] do %>
      <%= svg_icon 'list-ul-solid' %>
      Scoreboard
    <% end %>

    <% if editable %>
      <%= link_to edit_boogie_path(@event), class: ['page-tab page-tab-right', ('page-tab-active' if current_page?(edit_boogie_path(@event)))] do %>
        <%= svg_icon 'gear-solid' %>
        <%= t('general.edit') %>
      <% end %>
    <% end %>
  </div>
</div>
