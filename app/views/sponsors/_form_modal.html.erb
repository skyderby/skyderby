<% url = @sponsor.new_record? ?
           polymorphic_path([@sponsorable, @sponsor]) :
           polymorphic_path([@sponsorable, @sponsor]) %>

<%= form_with model: @sponsor, url:, scope: :sponsor, multipart: true,
              data: { controller: 'modal-form', action: 'form:submit-success->modal#close' } do |f| %>
  <div class="sd-form">
    <div class="grid">
      <%= f.label :name, class: 'form-label col-3' %>
      <%= f.text_field :name, class: 'form-input col-9', required: true %>
    </div>

    <div class="grid">
      <%= f.label :website, class: 'form-label col-3' %>
      <%= f.text_field :website, class: 'form-input col-9', placeholder: 'https://example.com', required: true %>
    </div>

    <div class="grid">
      <%= f.label :logo, class: 'form-label col-3' %>
      <div class="col-9">
        <div data-controller="filefield">
          <%= f.file_field :logo, class: 'form-input',
                         data: {
                           filefield_target: 'file_field',
                           action: 'change->filefield#change'
                         },
                         required: true %>
          <div class="file-name" data-filefield-target="text_field"></div>
        </div>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
      <button type="button" class="button" data-action="modal#close"><%= t 'general.cancel' %></button>
    </div>
  </div>
<% end %>