<%= form_for(@country, html: { class: 'form-horizontal' }) do |f| %>
  <% if @country.errors.any? %>
    <div id="error_explanation">
      <h2>
        <%= pluralize(@country.errors.count, "error") %>
        <%= 'prohibited this country from being saved:' %>
      </h2>
      <ul>
        <% @country.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, class: 'col-sm-2 control-label', for: :name %>
    <div class="col-sm-5">
      <%= f.text_field :name, autofocus: true, class: 'form-control' %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :code, class: 'col-sm-2 control-label', for: :code %>
    <div class="col-sm-5">
      <%= f.text_field :code, class: 'form-control' %>
    </div>
  </div>

  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-8">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
    </div>
  </div>
<% end %>
