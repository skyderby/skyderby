<%= turbo_stream.append 'tracks-list' do %>
  <%= render partial: 'flight_profiles/track', collection: @tracks, as: :track %>
<% end %>

<% if @tracks.next_page %>
  <%= turbo_stream.update 'tracks-pagination' do %>
    <%= button_to t('will_paginate.load_more', default: 'Load more...'),
                  polymorphic_path([@scope, :flight_profiles, :tracks]),
                  params: { page: @tracks.next_page },
                  form: { data: { turbo: true, turbo_stream: true } },
                  method: :get,
                  class: 'btn btn-default' %>
  <% end %>
<% else %>
  <%= turbo_stream.remove 'tracks-pagination' %>
<% end %>
