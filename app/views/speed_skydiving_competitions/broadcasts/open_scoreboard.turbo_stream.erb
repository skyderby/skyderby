<%# locals: (event:, editable:) %>

<%= turbo_stream.replace 'open-scoreboard', method: :morph do %>
  <% if !editable && event.surprise? %>
    <%= render 'speed_skydiving_competitions/surprise' %>
  <% else %>
    <%= render 'speed_skydiving_competitions/open_scoreboards/scoreboard', event:, editable: %>
  <% end %>
<% end %>
