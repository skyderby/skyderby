<%= turbo_stream.update 'modal-root' do %>
  <%= render partial: 'result', layout: 'components/modal', locals: {
    title: "Result: #{@result.competitor.name} - Round #{@result.round.number}",
    modal_size: 'lg',
    event: @event,
    editable: @event.editable?,
    result: @result
  } %>
<% end %>
