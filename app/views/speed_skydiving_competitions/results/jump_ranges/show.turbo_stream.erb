<%= turbo_stream.update 'modal-root' do %>
  <%= render partial: 'jump_range', layout: 'modals/modal', locals: {
    title: "Result: #{@result.competitor.name} - Round #{@result.round.number}",
    modal_size: 'lg',
    event: @event,
    editable: @event.editable? && !@event.finished? && !@result.round.completed?,
    result: @result
  } %>
<% end %>
