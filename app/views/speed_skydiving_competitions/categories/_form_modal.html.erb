<%= form_with model: @category,
              url: speed_skydiving_competition_categories_path(@event),
              scope: :category,
              data: { controller: 'events--categories-form', action: 'form:submit-success->modal#close' } do |f| %>
  <div class="category-form">
    <div class="form-row">
      <%= f.label :name, class: 'form-label' %>
      <%= f.text_field :name, class: 'form-input' %>
    </div>

    <div class="form-actions">
      <%= f.submit 'Save', class: 'primary-button' %>
    </div>
  </div>
<% end %>
