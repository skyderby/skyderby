<%# locals: (event:, category:) %>
<% fallers = category.fallers %>
<% half = (fallers.size / 2.0).ceil %>

<div class="display-slide display-fall"
     data-slideshow-target="slide"
     data-slideshow-duration="23"
     data-controller="speed-fall"
     data-finish-label="<%= t('speed_skydiving_competitions.display.window_end') %>">
  <%= render 'statusbar', event: event %>

  <script type="application/json" data-speed-fall-target="data"><%= raw fallers.to_json %></script>

  <div class="display-fall-body">
    <div class="display-fall-side">
      <% fallers.first(half).each do |faller| %>
        <%= render 'fall_card', faller: faller %>
      <% end %>
    </div>

    <div class="display-fall-center">
      <div class="display-fall-center-head"><%= category.name %></div>
      <div class="display-fall-stage">
        <svg class="display-fall-svg" data-speed-fall-target="svg"
             preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
        <div class="display-fall-countdown" data-speed-fall-target="countdown" hidden>
          <span class="count" data-speed-fall-target="countText">3</span>
        </div>
      </div>
    </div>

    <div class="display-fall-side">
      <% fallers.drop(half).each do |faller| %>
        <%= render 'fall_card', faller: faller %>
      <% end %>
    </div>
  </div>
</div>
