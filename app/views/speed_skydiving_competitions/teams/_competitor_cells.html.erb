<%# locals: (event:, editable:, competitor:, score:) %>

<td class="competitor">
  <% if competitor %>
    <%= link_to competitor.name, profile_path(competitor.profile), class: 'competitor-profile' %>
    <% if editable %>
      <div class="cell-actions" data-controller="dropdown">
        <button class="dropdown-toggle button button--ghost button--sm" popovertarget="speed-team-competitor-menu-<%= competitor.id %>">
          <%= icon_tag 'ellipsis-vertical-solid' %>
        </button>

        <div id="speed-team-competitor-menu-<%= competitor.id %>" popover class="sd-dropdown-menu" data-dropdown-target="menu">
          <%= button_to 'Delete', speed_skydiving_competition_team_competitor_path(event, competitor),
                        class: 'dropdown-item',
                        method: :delete, form: { data: { turbo_stream: true, confirm: 'This action is irreversible. Proceed?' } } %>
        </div>
      </div>
    <% end %>
  <% end %>
</td>
<% if score %>
  <td class="text-right"><%= score[:score] %></td>
  <td class="text-right"><%= score[:percent] %></td>
<% else %>
  <td></td>
  <td></td>
<% end %>
