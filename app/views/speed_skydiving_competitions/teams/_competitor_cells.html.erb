<%# locals: (event:, editable:, competitor:, score:) %>

<td class="competitor">
  <% if competitor %>
    <%= link_to competitor.name, profile_path(competitor.profile), class: 'competitor-profile' %>
    <% if editable %>
      <div class="cell-actions">
        <div class="sd-dropdown" data-controller="dropdown">
          <button class="dropdown-toggle ghost-button small-button" data-action="click->dropdown#toggle">
            <%= svg_icon 'ellipsis-vertical-solid' %>
          </button>
          <template data-target="dropdown.menu">
            <div class="sd-dropdown-menu">
              <%= button_to 'Delete', speed_skydiving_competition_team_competitor_path(event, competitor),
                            class: 'dropdown-item',
                            method: :delete, form: { data: { turbo_stream: true, confirm: 'This action is irreversible. Proceed?' } } %>
            </div>
          </template>
        </div>
      </div>
    <% end %>
  <% end %>
</td>
<% if score %>
  <td class="text-right"><%= score[:score] %></td>
  <td class="text-right"><%= score[:percent] %></td>
<% else %>
  <td></td>
  <td></td>
<% end %>
