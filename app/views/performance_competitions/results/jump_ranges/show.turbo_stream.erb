<% editable = @event.editable? && !@event.finished? && !@result.round.completed? %>

<%= turbo_stream.update 'modal-root' do %>
  <%= render partial: 'jump_range_form',
             layout: 'components/dialog',
             locals: {
               title: event_result_presentation(@result),
               result: @result,
               modal: true,
               modal_size: 'lg',
               editable:
             } %>
<% end %>
