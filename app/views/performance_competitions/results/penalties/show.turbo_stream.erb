<% editable = @event.editable? && !@event.finished? && !@result.round.completed? %>
<% minimal = params.key? :minimal %>

<%= turbo_stream.update 'modal-root' do %>
  <%= render partial: 'penalties_form',
             layout: 'components/modal',
             locals: {
               title: event_result_presentation(@result),
               minimal:,
               modal_size: minimal ? :md : :lg,
               editable:,
               result: @result,
               modal: true,
             } %>
<% end %>
