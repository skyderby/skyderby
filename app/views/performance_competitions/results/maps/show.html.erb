<% if user_signed_in? %>
  <% editable = @event.editable? && !@event.finished? && !@result.round.completed? %>

  <%= render partial: 'map',
             layout: 'performance_competitions/results/layout',
             locals: {
               result: @result,
               editable:
             } %>
<% else %>
  <%= render 'components/maps_auth_wall' %>
<% end %>
