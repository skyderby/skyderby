<% provide :title, @event.name %>
<% editable = policy(@event).update? %>

<div class="show-page">
  <%= render 'events/header', editable: %>

  <div class="show-page-content">
    <% if @event.surprise? && !editable %>
      <h1 class="text-muted text-center">🙅 Let it be a Surprise</h1>
    <% else %>
      <%= render 'performance_competitions/open_scoreboards/scoreboard', event: @event, editable: %>
    <% end %>
  </div>
</div>
