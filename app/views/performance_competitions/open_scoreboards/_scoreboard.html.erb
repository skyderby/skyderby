<%# locals: (event:, editable:, wind_cancellation: false) %>
<% id = ['open_scoreboard', ('no_wind' if wind_cancellation)].compact.join('_') %>

<% if event.surprise? && !editable %>
  <h1 class="text-muted text-center" id="<%= id %>">🙅 Let it be a Surprise</h1>
<% else %>
  <%= render 'performance_competitions/scoreboard_table',
             event: event, scoreboard: event.open_standings(wind_cancellation:), editable:, id: %>
<% end %>
