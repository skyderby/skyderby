<%# locals: (event:, editable:) %>
<% id = 'open_scoreboard' %>

<% if event.surprise? && !editable %>
  <h1 class="text-muted text-center" id="<%= id %>">🙅 Let it be a Surprise</h1>
<% else %>
  <%= render 'performance_competitions/scoreboard',
             event: event, scoreboard: event.open_standings, editable: editable, id: %>
<% end %>
