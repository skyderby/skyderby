<%# locals: (event:, editable:, wind_cancellation: false) %>
<% id = ['teams-scoreboard', ('no_wind' if wind_cancellation)].compact.join('_') %>

<% if event.surprise? && !editable %>
  <h1 class="text-muted text-center" id="<%= id %>">🙅 Let it be a Surprise</h1>
<% else %>
  <% standings = event.team_standings(wind_cancellation:) %>

  <% ranking = standings.ranking %>
  <% podium_enabled = ranking.size >= 3 %>

  <div class="scoreboard-container" id="<%= id %>">
    <table class="scoreboard-table team-standings-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Team</th>
          <th>Competitor</th>
          <th>Score</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% ranking.each_with_index do |row, index| %>
          <% team = row.team %>
          <% rank = row.rank %>
          <% on_podium = podium_enabled && row.total_points.to_f.positive? && rank <= 3 %>
          <% team_classes = class_names('team-row--striped' => index.even?, "podium-row--#{rank}" => on_podium) %>
          <% individual_standings = row.ranks %>
          <% rowspan = [individual_standings.size, 1].max %>
          <% first_row, *other_rows = individual_standings %>
          <tr class="<%= team_classes %>">
            <td rowspan="<%= rowspan %>" class="text-center">
              <% if on_podium %>
                <span class="rank-badge rank-badge--<%= rank %>"><%= rank %></span>
              <% else %>
                <%= rank %>
              <% end %>
            </td>
            <td rowspan="<%= rowspan %>" class="team">
              <%= team.name %>
              <% if editable %>
                <div class="cell-actions" data-controller="dropdown">
                  <button class="dropdown-toggle button button--ghost button--sm" popovertarget="perf-team-menu-<%= team.id %>">
                    <%= icon_tag 'ellipsis-vertical-solid' %>
                  </button>

                  <div id="perf-team-menu-<%= team.id %>" popover class="sd-dropdown-menu" data-dropdown-target="menu">
                    <%= button_to 'Edit', edit_performance_competition_team_path(event, team),
                                  class: 'dropdown-item',
                                  method: :get, form: { data: { turbo_stream: true } } %>

                    <%= button_to 'Delete', performance_competition_team_path(event, team),
                                  class: 'dropdown-item',
                                  method: :delete, form: { data: { turbo_stream: true, confirm: 'This action is irreversible. Proceed?' } } %>
                  </div>
                </div>
              <% end %>
            </td>
            <% if first_row %>
              <%= render 'performance_competitions/teams/competitor_cells', individual_standings: first_row, event:, editable: %>
            <% else %>
              <td colspan="2">-</td>
            <% end %>
            <td rowspan="<%= rowspan %>" class="text-right"><%= row.total_points.round(1) %></td>
          </tr>
          <% other_rows.each do |member_row| %>
            <tr class="<%= team_classes %>">
              <%= render 'performance_competitions/teams/competitor_cells', individual_standings: member_row, event:, editable: %>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
