<% provide :title, @event.name %>
<% editable = @event.editable? %>

<div class="show-page">
  <%= render 'performance_competitions/header', editable: %>

  <div class="card fill-entirely grid" data-controller="events--reference-points">
    <div class="col-4">
      <div class="event-reference-points__actions top-buffer">
        <button class="btn btn-default" data-action="click->events--reference-points#add">
          <i class="fa fa-plus"></i>
          <%= t('general.create') %>
        </button>
      </div>
      <%= form_for @event, url: performance_competition_reference_points_path(@event), remote: true do |form| %>
        <table class="table event-reference-points__table">
          <thead>
            <tr>
              <th><%= t('activerecord.attributes.reference_point.name') %></th>
              <th><%= t('activerecord.attributes.reference_point.latitude') %></th>
              <th><%= t('activerecord.attributes.reference_point.longitude') %></th>
              <th></th>
            </tr>
          </thead>
          <tbody class="hide" data-target="events--reference-points.template">
            <%= render 'performance_competitions/reference_points/template', form: form %>
          </tbody>
          <tbody data-target="events--reference-points.container">
            <%= form.fields_for :reference_points, include_id: false do |points_form| %>
              <%= render 'performance_competitions/reference_points/fields', form: points_form %>
            <% end %>
          </tbody>
        </table>
        <hr>
        <% PerformanceCompetition.designated_lane_starts.each do |value, index| %>
          <div class="radio">
            <label>
              <%= form.radio_button :designated_lane_start, value %>
              <%= t "activerecord.attributes.event.designated_lane_starts.#{value}" %>
            </label>
          </div>
        <% end %>
        <hr>
        <div class="text-right">
          <%= form.submit t('general.save'), class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>

    <div class="event-reference-points__map col-8"
         data-target="events--reference-points.map"
         data-center-lat="<%= @event.place.latitude %>"
         data-center-lon="<%= @event.place.longitude %>">
    </div>
  </div>
</div>
