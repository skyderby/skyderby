<tr data-target="events--reference-points.point">
  <td><%= form.text_field :name %></td>
  <td><%= form.number_field :latitude, step: '0.0000001', class: 'reference-point__latitude' %></td>
  <td><%= form.number_field :longitude, step: '0.0000001', class: 'reference-point__longitude' %></td>
  <td>
    <%= form.hidden_field :id %>
    <%= form.hidden_field :_destroy %>
    <a class="event-reference-points__delete" data-action="click->events--reference-points#remove">
      <i class="fa fa-times"></i>
    </a>
  </td>
</tr>
