<% provide :title, @event.name %>
<% editable = @event.editable? %>
<%= turbo_stream_from @event, :task_scoreboard, @task, editable ? :editable : :read_only %>

<div class="show-page">
  <%= render 'events/header', editable: %>

  <div class="show-page-content">
    <div class="tab-bar">
      <% @tasks.each do |task| %>
        <%= link_to t("disciplines.#{task}"), performance_competition_task_scoreboard_path(@event, task), class: class_names('tab-bar-item', ('active' if @task == task)) %>
      <% end %>
    </div>

    <% if @event.wind_cancellation %>
      <%= render 'actions_bar', event: @event %>
    <% end %>

    <div id="<%= @task %>_scoreboard">
      <%= render 'scoreboard', event: @event, editable:, task: @task, wind_cancellation: @wind_cancellation %>
    </div>
  </div>
</div>
