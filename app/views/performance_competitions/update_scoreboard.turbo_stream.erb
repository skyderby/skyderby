<% if @toast %>
  <%= turbo_stream.append(:toasts, partial: 'toasts/toast', locals: @toast) %>
<% end %>

<%= turbo_stream.replace 'scoreboard' do %>
  <%= render 'performance_competitions/scoreboard', event: @event, editable: true, wind_cancellation: false %>
<% end %>

<%= turbo_stream.replace 'scoreboard_no_wind' do %>
  <%= render 'performance_competitions/scoreboard', event: @event, editable: true, wind_cancellation: true %>
<% end %>
