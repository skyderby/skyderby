<%# locals: (event:, editable:) %>

<div class="card actions-bar" id="actions-bar">
  <% if editable && !event.finished? %>
    <%= button_to new_performance_competition_category_path(event), method: :get, form: { data: { turbo_stream: true } }, class: 'actions-bar-button' do %>
      <%= svg_icon 'plus-solid' %>
      <%= t('activerecord.models.event/section') %>
    <% end %>

    <%= button_to new_performance_competition_competitor_path(event), method: :get, form: { data: { turbo_stream: true } }, class: 'actions-bar-button' do %>
      <%= svg_icon 'plus-solid' %>
      <%= t('activerecord.models.event/competitor') %>
    <% end %>

    <div class="sd-dropdown" data-controller="dropdown">
      <button class="actions-bar-button" data-action="click->dropdown#toggle">
        <%= svg_icon 'plus-solid' %>
        <%= t('activerecord.models.event/round') %>
        <%= svg_icon 'angle-down-solid' %>

        <template data-dropdown-target="menu">
          <div class="sd-dropdown-menu">
            <% %i[distance speed time].each do |task| %>
              <%= button_to(t("disciplines.#{task}"),
                            performance_competition_rounds_path(event),
                            method: :post,
                            params: { 'round[discipline]' => task },
                            class: 'dropdown-item') %>
            <% end %>
          </div>
        </template>
      </button>
    </div>
  <% end %>

  <div class="sd-dropdown actions-bar-right">
    <% if event.wind_cancellation %>
      <%= form_with url: url_for, method: :get, data: { controller: 'auto-submit' }, class: 'actions-bar-button' do |form| %>
        <%= form.switch :including_wind,
                        checked: params[:including_wind] == '1',
                        data: { action: 'change->auto-submit#submit' },
                        label_text: 'Wind cancellation',
                        include_hidden: false,
                        reverse_visual: true %>
      <% end %>
    <% end %>

    <% if editable %>
      <button class="actions-bar-button" data-controller="dropdown" data-action="click->dropdown#toggle">
        <%= t('activerecord.attributes.event.status') + ': ' + t('event_status.' + event.status) %>
        <%= svg_icon 'angle-down-solid' %>

        <template data-dropdown-target="menu">
          <div class="sd-dropdown-menu">
            <% PerformanceCompetition.statuses.each do |status, _index| %>
              <%= button_to(t("event_status.#{status}"),
                          performance_competition_path(event),
                          method: :patch,
                          form: { data: { turbo_stream: true } },
                          params: { 'performance_competition[status]' => status },
                          class: "dropdown-item #{'active' if event.status == status}") %>
            <% end %>
          </div>
        </template>
      </button>

      <button class="actions-bar-button" data-controller="dropdown" data-action="click->dropdown#toggle" title="More actions">
        <%= svg_icon 'gear-solid' %>

        <template data-dropdown-target="menu">
          <div class="sd-dropdown-menu">
            <div class="dropdown-header">Copy</div>
            <%= button_to 'Copy competitors',
                          new_performance_competition_competitors_copy_path(event),
                          method: :get,
                          form: { data: { turbo_stream: true } },
                          class: 'dropdown-item' %>
            <%= button_to 'Copy results',
                          new_performance_competition_results_copy_path(event),
                          method: :get,
                          form: { data: { turbo_stream: true } },
                          class: 'dropdown-item' %>
          </div>
        </template>
      </button>
    <% end %>
  </div>
</div>
