<turbo-frame id="<%= sanitize params[:frame_id] %>">
  <div class="hot-select-options">
    <% @places.group_by(&:country).each do |country, places| %>
      <div class="hot-select-option-group">
        <%= country.name %>
      </div>

      <% places.each do |place| %>
        <div class="hot-select-option" data-value="<%= place.id %>">
          <%= place.name %>
        </div>
      <% end %>
    <% end %>

    <% if @places.total_pages > @places.current_page %>
      <% next_page = @places.current_page + 1 %>
      <% frame_id = "#{sanitize params[:frame_id]}-#{next_page}" %>
      <%= render 'hot_select/load_more', page: next_page, frame_id: %>
    <% end %>
  </div>
</turbo-frame>
