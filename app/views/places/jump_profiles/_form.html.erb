<% url = @jump_profile.new_record? ? place_jump_profiles_path(@place) : place_jump_profile_path(@place, @jump_profile) %>
<%= form_with model: @jump_profile, url:, data: { 'controller': 'places--jump-profile-form' }, class: 'form-horizontal' do |form| %>
  <div class="form-group">
    <%= form.label :name, class: 'col-sm-3 control-label' %>
    <div class="col-sm-5">
      <%= form.text_field :name, class: 'form-control' %>
    </div>
  </div>
  <div class="form-group" data-controller="places--exit-measurements">
    <label class="col-sm-3 control-label">Exit measurements</label>
    <div class="col-sm-5">
      <table class="table place-form__exit-measurements">
        <thead>
          <tr>
            <th>Altitude</th>
            <th>Distance</th>
            <th></th>
          </tr>
        </thead>
        <tbody class="hide exit-measurement__template" data-places--exit-measurements-target="template">
          <%= render 'places/jump_profiles/exit_measurements_template', form: form, line: form.object %>
        </tbody>
        <tbody data-places--exit-measurements-target="container">
          <%= render 'places/jump_profiles/exit_measurements', form: form %>
        </tbody>
      </table>
      <a class="button place-form__add-measurement" data-action="click->places--exit-measurements#add">
        <%= icon_tag 'plus-solid' %>
        Add
      </a>
      <a class="button" data-action="click->places--exit-measurements#addFromText">
        <%= icon_tag 'plus-solid' %>
        Add from text
      </a>
      <textarea rows="10" data-places--exit-measurements-target="textarea"></textarea>
    </div>
  </div>

  <hr>

  <div class="text-center">
    <% if @jump_profile.persisted? %>
      <%= link_to t('general.delete'), place_jump_profile_path(@place, @jump_profile), class: 'button button--danger', data: { turbo_method: :delete, turbo_confirm: t('general.confirm_delete') } %>
    <% end %>
    <%= form.submit t('general.save'), class: 'button button--primary' %>
  </div>
<% end %>
