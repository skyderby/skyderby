<turbo-frame id="<%= sanitize params[:frame_id] %>">
  <div class="hot-select-options">
    <% @finish_lines.each do |finish_line| %>
      <div class="hot-select-option" data-value="<%= finish_line.id %>">
        <%= finish_line.name %>
      </div>
    <% end %>

    <% if @finish_lines.next_page %>
      <% frame_id = "#{sanitize params[:frame_id]}-#{@finish_lines.next_page}" %>
      <%= render 'hot_select/load_more', page: @finish_lines.next_page, frame_id: %>
    <% end %>
  </div>
</turbo-frame>
