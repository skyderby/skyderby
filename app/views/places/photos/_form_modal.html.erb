<%= form_with model: [@place, @photo], data: { controller: 'modal-form', action: 'form:submit-success->dialog#close' } do |f| %>
  <div class="sd-form">
    <div class="grid">
      <%= f.label :image, t('activerecord.attributes.place/photo.image'), class: 'form-label col-4' %>
      <div class="col-8">
        <%= f.file_field :image, class: 'form-input' %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit t('general.save'), class: 'button button--primary' %>
      <button type="button" class="button" data-action="dialog#close"><%= t('general.cancel') %></button>
    </div>
  </div>
<% end %>
