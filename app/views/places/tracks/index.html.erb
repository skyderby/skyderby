<%= render 'places/layout' do %>
  <div id="tracks-table" class="table table-hover">
    <div class="thead">
      <%= render 'tracks/table_header' %>
    </div>
    <div id="tracks-list" class="tbody">
      <%= render collection: @tracks, partial: 'tracks/track' %>
    </div>
  </div>

  <div class="flex justify-center">
    <div class="pagination">
      <%= paginate @tracks %>
    </div>
  </div>
<% end %>
