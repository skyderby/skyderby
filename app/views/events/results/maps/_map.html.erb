<% show_cancel ||= false %>
<% wrap_in_container ||= false %>

<div class="<%= wrap_in_container ? 'container-fluid' : '' %>"
     data-controller="events--result-map"
     data-url="<%= url_for %>"
     data-action="maps_api:ready@window->events--result-map#on_maps_ready maps_api:failed@window->events--result-map#on_maps_failed_load">

  <div class="row">
    <div class="col-sm-12" data-controller="events--designated-lane"
         data-action="round-map:show-dl@window->events--designated-lane#show_dl">
      <div class="<%= mobile? ? 'hide' : '' %>">
        <%= render 'events/maps/designated_lane_form' %>
      </div>

      <div class="event-track__map" data-target="events--result-map.map events--designated-lane.map">
        <div class="round-map-loading" data-target="events--round-map.loading_placeholder">
          <i class="fa fa-3x fa-circle-notch fa-spin"></i>
          <p>Loading...</p>
        </div>
      </div>

      <%= render 'events/maps/legend' %>
    </div>
  </div>

  <% show_actions = policy(@result.event).update? || show_cancel %>
  <% if show_actions %>
    <hr>
    <div class="modal-actions">
      <div class="modal-actions__left">
        <% if policy(@result.event).update? %>
          <%= delete_event_track_link(@result) %>
        <% end %>
      </div>

      <% if show_cancel %>
        <div class="modal-actions__right">
          <button class="btn btn-default" type="button" data-dismiss="modal"><%= t 'general.cancel' %></button>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
