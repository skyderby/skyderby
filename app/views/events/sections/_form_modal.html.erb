<% url = @section.new_record? ?
           event_sections_path(@event) :
           event_section_path(@event, @section) %>

<%= form_with model: @section, url:, scope: :section,
              data: { controller: 'modal-form', action: 'form:submit-success->modal#close' } do |f| %>
  <%= display_event_form_params %>
  
  <div class="sd-form">
    <div class="grid">
      <%= f.label :name, class: 'form-label col-3' %>
      <%= f.text_field :name, class: 'form-input col-9', required: true, autofocus: true %>
    </div>

    <div class="form-actions">
      <%= f.submit t('general.save'), class: 'primary-button' %>
      <button type="button" class="default-button" data-action="modal#close"><%= t 'general.cancel' %></button>
    </div>
  </div>
<% end %>
