<% provide :title, @event.name %>

<div class="event-edit">
  <div class="event-edit__header">
    <%= render 'events/edit_header' %>
  </div>

  <div class="event-edit__body">
    <div class="event-edit__sidebar">
      <%= render 'events/edit_sidebar' %>
    </div>

    <div class="event-edit__main-area">
      <%= form_with scope: :event_deletion, url: event_deletion_path(@event), html: { class: 'form-horizontal' } do |f| %>
        <h2 class="text-danger">Are you ABSOLUTELY sure?</h2>

        <p>
          This action
          <b>CANNOT</b>
          be undone. This will permanently delete the
          <b><%= @event.name %></b>.
          <br>
          Please type in the name of the event to confirm.
        </p>

        <div class="form-group">
          <div class="col-sm-12">
            <%= f.text_field :event_name, class: 'form-control input-lg' %>
          </div>
        </div>

        <div class="form-group">
          <div class="col-sm-12">
            <div class="checkbox">
              <label>
                <%= f.check_box :delete_tracks %>
                Delete tracks
              </label>
            </div>
          </div>
        </div>

        <hr>

        <div class="text-center">
          <%= f.submit t('general.delete'), class: 'btn btn-lg btn-danger' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
