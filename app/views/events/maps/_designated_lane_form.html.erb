<div class="designated-lane-form">
  <button class="btn btn-xs btn-default" data-events--designated-lane-target="button" data-action="click->events--designated-lane#toggle">
    Designated lane
  </button>
  <form class="form-inline">
    <div class="form-group">
      <label class="control-label" for="designated-lane-length">Length</label>
      <input id="designated-lane-length" class="form-control input-sm" type="number" value="7000" step="1000" disabled="true" data-events--designated-lane-target="length" data-action="input->events--designated-lane#on_change_length">
    </div>
    <div class="form-group">
      <label class="control-label" for="designated-lane-width">Width</label>
      <input id="designated-lane-width" class="form-control input-sm" type="number" value="1200" step="100" disabled="true" data-events--designated-lane-target="width" data-action="input->events--designated-lane#on_change_width">
    </div>
    <div class="form-group">
      <label class="control-label" for="designated-lane-direction">Direction</label>
      <input id="designated-lane-direction" class="form-control input-sm" type="number" value="0" step="0.1" disabled="true" data-events--designated-lane-target="direction" data-action="input->events--designated-lane#on_change_direction">
    </div>
  </form>
</div>
