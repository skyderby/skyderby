<% can_update ||= false %>
<% result_class ||= '' %>

<td class="<%= class_names 'result-cell', result_class %>">
  <%= link_to(performance_competition_result_path(event, result),
              **(mobile? ? { target: '_blank' } : { 'data-turbo-stream' => 'true' }),
              class: 'result-show-cell',
              rel: 'nofollow') do  %>
    <% if result.valid? %>
      <%= result.formated %>
      <% if result.penalized? && result.apply_penalty_to_result? %>
        <sup class="text-danger">-<%= result.penalty_size %>%</sup>
      <% end %>
    <% elsif can_update %>
      <%= icon_tag 'circle-question', class: 'text-danger' %>
    <% end %>
  <% end %>
</td>
