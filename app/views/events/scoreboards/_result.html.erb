<% can_update ||= false %>
<% result_class ||= '' %>

<td class="scoreboard-result <%= result_class %>">
  <% if result.valid? %>
    <%= result.formated %>
    <% if result.penalized? && result.apply_penalty_to_result? %>
      <sup class="text-danger">-<%= result.penalty_size %>%</sup>
    <% end %>
  <% elsif can_update %>
    <i class="far fa-question-circle text-danger"></i>
  <% end %>
  <span>
    <%= show_event_track_link(event, result, can_update) %>
  </span>
</td>
