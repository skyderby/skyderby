<% can_update = policy(@scoreboard.event).update? && !@scoreboard.event.finished? && !request.variant.include?(:mobile) %>

<% cache ['scoreboard', I18n.locale, @scoreboard.event, display_event_params, can_update] do %>
  <div class="<%= class_names 'scoreboard-container', (@scoreboard.rounds.size > 6 && 'scoreboard-container-fluid') %>"
       data-controller="events--sticky-header"
       id="scoreboard"
  >
    <div class="scoreboard-scroll" data-events--sticky-header-target="container" data-action="scroll->events--sticky-header#on_horizontal_scroll">
      <table class="scoreboard-table" data-events--sticky-header-target="table">
        <%= render 'events/scoreboard_header', event: @event, scoreboard: @scoreboard, editable: can_update %>
        <% @scoreboard.sections.each do |section| %>
          <tbody>
            <%= render 'events/sections/section_row', event: @event, section:, columns_count: @scoreboard.columns_count, editable: can_update %>
            <% rank = 0 %>
            <% prev_total = 0 %>
            <% section.competitors.each_with_index do |competitor, index| %>
              <% total_points = competitor.total_points.to_f %>
              <% rank = (total_points == prev_total && total_points.positive?) ? rank : index + 1 %>
              <% prev_total = total_points %>
              <tr class="scoreboard-competitor" id="<%= dom_id(competitor) %>">
                <td class="text-center"><%= rank %></td>
                <%= render 'events/competitors/competitor_cells', event: @event, competitor:, editable: can_update %>
                <% @scoreboard.rounds_by_discipline.each do |discipline, rounds| %>
                  <% rounds.each do |round| %>
                    <% result = @scoreboard.results.for(competitor: competitor, round: round) %>
                    <% if result && (round.completed || can_update) %>
                      <%= render 'events/scoreboards/result', { event: @scoreboard.event, result: result, can_update: can_update, result_class: ('text-green' if result.best_in_round_and_category?) } %>
                      <td class="text-right">
                        <% if round.completed %>
                          <% if result.penalized? %>
                            <span class="dotted-underline" data-toggle="tooltip" title="<%= result.penalty_reason %>">
                              <%= result.formated_points %>
                              <% if result.apply_penalty_to_score? %>
                                <sup class="text-danger">-<%= result.penalty_size %>%</sup>
                              <% end %>
                            </span>
                          <% else %>
                            <%= result.formated_points %>
                          <% end %>
                        <% end %>
                      </td>
                    <% elsif can_update %>
                      <td class="result-cell">
                        <%= new_event_track_link(@scoreboard.event, competitor, round) %>
                      </td>
                      <td></td>
                    <% else %>
                      <td></td>
                      <td></td>
                    <% end %>
                  <% end %>
                  <td class="text-right">
                    <% points_in_discipline = competitor.points_in_discipline(discipline) %>
                    <% if points_in_discipline&.positive? %>
                      <%= '%.1f' % points_in_discipline %>
                    <% end %>
                  </td>
                <% end %>
                <td class="scoreboard-total-result">
                  <% if competitor.total_points.positive? %>
                    <%= '%.1f' % competitor.total_points %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      </table>
    </div>
  </div>
<% end %>
