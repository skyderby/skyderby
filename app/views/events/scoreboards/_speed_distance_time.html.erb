<% can_update = policy(@scoreboard.event).update? && !@scoreboard.event.finished? && !request.variant.include?(:mobile) %>

<% cache ['scoreboard', I18n.locale, @scoreboard.event, display_event_params, can_update] do %>
  <div class="scoreboard" data-controller="events--sticky-header">
    <div class="scoreboard-scroll" data-target="events--sticky-header.container" data-action="scroll->events--sticky-header#on_horizontal_scroll">
      <table class="scoreboard-table" data-target="events--sticky-header.table">
        <thead>
          <tr>
            <th class="text-center" rowspan="3">#</th>
            <th rowspan="3" colspan="2"><%= t('activerecord.models.event/competitor') %></th>
            <% @scoreboard.rounds_by_discipline.each do |discipline, rounds| %>
              <th class="text-center" colspan="<%= rounds.count * 2 + 1 %>"><%= t('disciplines.' + discipline) %></th>
            <% end %>
            <th class="text-center" rowspan="3"><%= t('events.show.total') %></th>
          </tr>
          <tr>
            <% @scoreboard.rounds_by_discipline.each do |discipline, rounds| %>
              <% rounds.each do |round| %>
                <th class="scoreboard-round" colspan="2">
                  <div class="scoreboard-round-content">
                    <%= round.number %>
                    <% if can_update %>
                      <% if round.completed %>
                        &nbsp;<i class="fa fa-lock text-muted"></i>
                      <% else %>
                        &nbsp;<i class="fa fa-unlock-alt text-muted"></i>
                      <% end %>
                    <% end %>
                    <% if can_update || round.completed %>
                      <div class="scoreboard-round-actions dropdown">
                        <button class="btn-link" data-toggle="dropdown">
                          <i class="fa fa-ellipsis-v text-muted"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-right">
                          <li>
                            <%= link_to event_round_map_path(@event, round), rel: 'nofollow' do %>
                              <i class="fa fa-fw far fa-compass text-muted"></i>
                              Google maps
                            <% end %>
                          </li>
                          <li>
                            <%= link_to event_round_globe_path(@event, round), remote: true, class: 'round-map-view', rel: 'nofollow' do %>
                              <i class="fa fa-fw far fa-compass text-muted"></i>
                              3D maps
                            <% end %>
                          </li>
                          <li>
                            <%= link_to event_round_replay_path(@event, round), rel: 'nofollow' do %>
                              <i class="fa fa-fw fas fa-play text-muted"></i>
                              Replay
                            <% end %>
                          </li>
                          <% if can_update %>
                            <li class="divider"></li>
                            <li>
                              <% if round.completed %>
                                <%= button_to event_round_path(@event, round), method: :put, params: { round: { completed: false } }, remote: true, class: 'btn-link' do %>
                                  Mark uncomplete
                                <% end %>
                              <% else %>
                                <%= button_to event_round_path(@event, round), method: :put, params: { round: { completed: true } }, remote: true, class: 'btn-link' do %>
                                  Mark complete
                                <% end %>
                              <% end %>
                            </li>
                            <li class="divider"></li>
                            <li>
                              <%= button_to event_round_path(@event, round), method: :delete, remote: true, class: 'btn-link' do %>
                                <i class="fa fa-fw fa-times text-muted"></i>
                                <%= t('general.delete') %>
                              <% end %>
                            </li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                  </div>
                </th>
              <% end %>
              <th class="text-center" rowspan="2" data-discipline="<%= discipline %>" data-role="points">%</th>
            <% end %>
          </tr>
          <tr>
            <% @scoreboard.rounds_by_discipline.each do |discipline, rounds| %>
              <% rounds.each do %>
                <th class="text-center"><%= t('units.' + discipline_unit(discipline.to_sym).to_s) %></th>
                <th class="text-center">%</th>
              <% end %>
            <% end %>
          </tr>
        </thead>
        <% @scoreboard.sections.each do |section| %>
          <tbody>
            <%= render 'events/sections/section_row', section: section, columns_count: @scoreboard.columns_count, editable: can_update %>
            <% rank = 0 %>
            <% prev_total = 0 %>
            <% section.competitors.each_with_index do |competitor, index| %>
              <% total_points = competitor.total_points.to_f %>
              <% rank = (total_points == prev_total && total_points.positive?) ? rank : index + 1 %>
              <% prev_total = total_points %>
              <tr class="scoreboard-competitor" id="<%= dom_id(competitor) %>">
                <td class="text-center"><%= rank %></td>
                <%= render 'events/competitors/competitor_cells', competitor: competitor, editable: can_update %>
                <% @scoreboard.rounds_by_discipline.each do |discipline, rounds| %>
                  <% rounds.each do |round| %>
                    <% result = @scoreboard.results.for(competitor: competitor, round: round) %>
                    <% if result && (round.completed || can_update) %>
                      <%= render 'events/scoreboards/result', { event: @scoreboard.event, result: result, can_update: can_update, result_class: ('text-green' if result.best_in_round_and_category?) } %>
                      <td class="text-right">
                        <% if round.completed %>
                          <% if result.penalized? %>
                            <span class="dotted-underline" data-toggle="tooltip" title="<%= result.penalty_reason %>">
                              <%= result.formated_points %>
                              <% if result.apply_penalty_to_score? %>
                                <sup class="text-danger">-<%= result.penalty_size %>%</sup>
                              <% end %>
                            </span>
                          <% else %>
                            <%= result.formated_points %>
                          <% end %>
                        <% end %>
                      </td>
                    <% elsif can_update %>
                      <td class="scoreboard-result text-center">
                        <span><%= new_event_track_link(@scoreboard.event, competitor, round) %></span>
                      </td>
                      <td></td>
                    <% else %>
                      <td></td>
                      <td></td>
                    <% end %>
                  <% end %>
                  <td class="text-right">
                    <% points_in_discipline = competitor.points_in_discipline(discipline) %>
                    <% if points_in_discipline&.positive? %>
                      <%= '%.1f' % points_in_discipline %>
                    <% end %>
                  </td>
                <% end %>
                <td class="scoreboard-total-result">
                  <% if competitor.total_points.positive? %>
                    <%= '%.1f' % competitor.total_points %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      </table>
    </div>
  </div>
<% end %>
