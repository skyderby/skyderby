<div class="modal-dialog">
  <div class="modal-content">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal">
        <span aria-hidden="true">&times;</span>
        <span class="sr-only">Close</span>
      </button>
      <h4 class="modal-title"><%= t('tracks.choose.title') %></h4>
    </div>

    <div class="modal-body">
      <table class="table table-hover segments-table">
        <thead>
          <tr>
            <th><%= t('tracks.choose.number') %></th>
            <th><%= t('tracks.choose.name') %></th>
            <th><%= t('tracks.choose.elev') %></th>
            <th><%= t('tracks.choose.pt_cnt') %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @track_file.segments.each_with_index do |item, index| %>
            <tr class="track-segment-row">
              <td class="text-info"><%= index %></td>
              <td class="text-info"><%= item.name %></td>
              <td>
                <span class="text-primary"><%= "#{item.h_up}↑" %></span>
                <span class="text-success"><%= "#{item.h_down}↓" %></span>
                <%= t('units.m') %>
              </td>
              <td class="text-info"><%= item.points_count %></td>
              <td>
                <%= button_to track_file_track_path(@track_file), method: :post, params: track_file_params.slice(:track_attributes).merge(segment: index).to_h, class: 'btn-link' do %>
                  <i class="fa fa-2x fa-angle-double-right"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
