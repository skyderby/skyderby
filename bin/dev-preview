#!/usr/bin/env bash
# Single-process dev server for the Claude Code preview harness.
#
# bin/dev uses Procfile.local, which runs one-shot "scanner"/"ngrok" helpers
# that exit immediately and make foreman tear the whole group down, and a
# webpack-dev-server bound to a fixed port that collides with a developer's
# own running dev server. This wrapper avoids all of that: it runs Rails only
# and serves webpack-compiled packs (shakapacker compiles on demand via its
# mtime strategy when no dev-server is running). Pointing the dev-server port
# at an unused port keeps shakapacker from proxying to someone else's bundle.

export WEBPACKER_DEV_SERVER_PORT="${WEBPACKER_DEV_SERVER_PORT:-3199}"

exec bin/rails server -p "${PORT:-3000}"
